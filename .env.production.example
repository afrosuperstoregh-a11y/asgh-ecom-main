# Production Environment Variables
# Copy this file to .env.production and fill in your values

# Database Configuration
POSTGRES_DB=asca_ecom
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Application Configuration
NODE_ENV=production
JWT_SECRET=your_jwt_secret_key_here

# Payment Processing - Stripe
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here

# Payment Processing - PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_live_client_id_here
NEXT_PUBLIC_PAYPAL_ENVIRONMENT=live

# Email Configuration - SendGrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
NEXT_PUBLIC_SENDGRID_FROM_EMAIL=noreply@afrosuperstore.ca
NEXT_PUBLIC_SENDGRID_REPLY_TO=support@afrosuperstore.ca

# Redis Configuration
REDIS_URL=redis://redis:6379

# Frontend Configuration
NEXT_PUBLIC_API_URL=https://asca-ecom.com/api
NEXT_PUBLIC_SITE_URL=https://asca-ecom.com

# Monitoring
GRAFANA_PASSWORD=your_grafana_password_here

# Email Configuration (Optional - Legacy)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Cloud Storage (Optional)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_s3_bucket_name

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
GOOGLE_TAG_MANAGER_ID=GTM_CONTAINER_ID

# Security
CORS_ORIGIN=https://asca-ecom.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# SSL/TLS
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
