{
  "version": 2,
  "name": "asca-ecommerce-platform",
  "builds": [
    {
      "src": "ecommerce-platform/frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "ecommerce-platform/api/package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/ecommerce-platform/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/ecommerce-platform/frontend/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_SITE_URL": "https://asca-ecommerce.vercel.app",
    "NEXT_PUBLIC_API_URL": "https://asca-ecommerce.vercel.app/api"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ]
}
