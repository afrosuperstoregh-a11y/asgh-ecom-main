{
  "version": 2,
  "name": "asca-ecommerce-platform",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/.next",
  "framework": "nextjs",
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "functions": {
    "app/api/**/*.js": {
      "runtime": "nodejs20.x"
    },
    "app/api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "installCommand": "cd frontend && npm install"
}
