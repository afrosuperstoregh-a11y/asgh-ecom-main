{
  "version": 2,
  "name": "asca-ecommerce-platform",
  "buildCommand": "cd ecommerce-platform/frontend && npm run build",
  "outputDirectory": "ecommerce-platform/frontend/.next",
  "installCommand": "cd ecommerce-platform/frontend && npm install",
  "framework": "nextjs",
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "functions": {
    "ecommerce-platform/frontend/app/api/**/*.js": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "env": {
    "DATABASE_URL": "@database_url",
    "NEXTAUTH_URL": "@nextauth_url",
    "NEXTAUTH_SECRET": "@nextauth_secret",
    "STRIPE_SECRET_KEY": "@stripe_secret_key",
    "STRIPE_PUBLISHABLE_KEY": "@stripe_publishable_key",
    "STRIPE_WEBHOOK_SECRET": "@stripe_webhook_secret",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY": "@stripe_publishable_key",
    "SENDGRID_API_KEY": "@sendgrid_api_key",
    "FROM_EMAIL": "@from_email",
    "CANADA_POST_USERNAME": "@canada_post_username",
    "CANADA_POST_PASSWORD": "@canada_post_password",
    "CANADA_POST_CUSTOMER_NUMBER": "@canada_post_customer_number",
    "GOOGLE_CLIENT_ID": "@google_client_id",
    "GOOGLE_CLIENT_SECRET": "@google_client_secret"
  }
}
