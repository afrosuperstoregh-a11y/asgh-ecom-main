generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String  @id @default(uuid())
  email             String  @unique
  name              String?
  password          String?
  phone             String?
  emailVerified     Boolean @default(false)
  emailVerificationToken String?
  emailVerificationExpires DateTime?
  resetPasswordToken String?
  resetPasswordExpires DateTime?
  lastLoginAt       DateTime?
  loginAttempts     Int     @default(0)
  lockedUntil       DateTime?
  avatar            String?
  dateOfBirth       DateTime?
  gender            String?
  timezone          String  @default("UTC")
  language          String  @default("en")
  isActive          Boolean @default(true)
  isGuest           Boolean @default(false)
  role              UserRole @default(CUSTOMER)
  vendorId          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  carts             Cart[]
  orders            Order[]
  addresses         Address[]
  paymentMethods    PaymentMethod[]
  reviews           ProductReview[]
  sessions          UserSession[]
  socialAccounts    SocialAccount[]
  wishlistItems     WishlistItem[]
  userTokens        UserToken[]
  promotionUsage    PromotionUsage[]
  vendor            Vendor? @relation(fields: [vendorId], references: [id])
  customerLoyalty   CustomerLoyalty?
  subscriptions     CustomerSubscription[]
  pointsTransactions PointsTransaction[]
  pointsRedemptions PointsRedemption[]
  affiliate         Affiliate?
  securitySessions  SecuritySession[]
  securityAudits    SecurityAudit[]
  dataSubjectRequests DataSubjectRequest[]
  consentRecords    ConsentRecord[]
  paymentCards      PaymentCard[]
  paymentSecurityEvents PaymentSecurityEvent[]
  securityTraining  SecurityTraining[]
  
  @@map("users")
}

model Category {
  id          String @id @default(uuid())
  name        String @unique
  slug        String @unique
  description String?
  image       String?
  parentId    String?
  isActive    Boolean @default(true)
  sortOrder   Int @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  seo         CategorySEO?
  
  @@map("categories")
}

model Product {
  id          String @id @default(uuid())
  name        String
  slug        String @unique
  description String?
  shortDesc   String?
  sku         String @unique
  price       Decimal
  comparePrice Decimal?
  cost        Decimal?
  trackInventory Boolean @default(true)
  stock       Int @default(0)
  weight      Decimal?
  dimensions  Json? // {length, width, height}
  images      Json? // Array of image URLs
  tags        Json? // Array of tags
  status      ProductStatus @default(DRAFT)
  featured    Boolean @default(false)
  categoryId  String
  vendorId    String?
  isMarketplace Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  category    Category @relation(fields: [categoryId], references: [id])
  vendor      Vendor? @relation("VendorProducts", fields: [vendorId], references: [id])
  cartItems   CartItem[]
  orderItems  OrderItem[]
  reviews     ProductReview[]
  variants    ProductVariant[]
  analytics   ProductAnalytics[]
  vendorProducts VendorProduct[]
  subscriptionItems SubscriptionItem[]
  loyaltyRewards LoyaltyReward?
  affiliateLinks AffiliateLink[]
  
  @@map("products")
}

model ProductReview {
  id        String @id @default(uuid())
  productId String
  userId    String?
  rating    Int // 1-5
  title     String?
  content   String?
  verified  Boolean @default(false)
  helpful   Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  product   Product @relation(fields: [productId], references: [id])
  user      User? @relation(fields: [userId], references: [id])
  
  @@map("product_reviews")
}

model Cart {
  id        String @id @default(uuid())
  userId    String?
  sessionId String?
  status    CartStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  user      User? @relation(fields: [userId], references: [id])
  items     CartItem[]
  
  @@unique([userId, status])
  @@unique([sessionId, status])
  @@map("carts")
}

model CartItem {
  id        String @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  price     Decimal // Price at time of adding to cart
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  cart      Cart @relation(fields: [cartId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
  
  @@unique([cartId, productId])
  @@map("cart_items")
}

model Address {
  id        String @id @default(uuid())
  userId    String
  type      AddressType @default(SHIPPING)
  firstName String
  lastName  String
  company   String?
  address1  String
  address2  String?
  city      String
  province  String
  country   String
  postalCode String
  phone     String?
  isDefault Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  user      User @relation(fields: [userId], references: [id])
  
  @@map("addresses")
}

model Order {
  id                String @id @default(uuid())
  orderNumber       String @unique
  userId            String?
  guestEmail        String?
  status            OrderStatus @default(PENDING)
  currency          String @default("USD")
  subtotal          Decimal
  taxAmount         Decimal @default(0)
  shippingAmount    Decimal @default(0)
  discountAmount    Decimal @default(0)
  total             Decimal
  notes             String?
  shippingAddress   Json? // Address data snapshot
  billingAddress    Json? // Address data snapshot
  paymentStatus     PaymentStatus @default(PENDING)
  paymentMethod     String?
  paymentId         String?
  trackingNumber    String?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  isMultiVendor     Boolean @default(false)
  vendorCount       Int @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  user              User? @relation(fields: [userId], references: [id])
  items             OrderItem[]
  payments          Payment[]
  statusHistory     OrderStatusHistory[]
  orderNotes        OrderNote[]
  promotionUsage    PromotionUsage[]
  invoice           Invoice?
  vendorOrders      VendorOrder[]
  
  @@map("orders")
}

model OrderItem {
  id          String @id @default(uuid())
  orderId     String
  productId   String
  productName String // Product name snapshot
  productSku  String // Product SKU snapshot
  quantity    Int
  price       Decimal // Price at time of purchase
  total       Decimal // quantity * price
  createdAt   DateTime @default(now())
  
  // Relations
  order       Order @relation(fields: [orderId], references: [id])
  product     Product @relation(fields: [productId], references: [id])
  
  @@map("order_items")
}

model PaymentMethod {
  id            String @id @default(uuid())
  userId        String
  type          PaymentMethodType @default(CARD)
  provider      String // stripe, paypal, etc.
  providerId    String // Token from payment provider
  last4         String?
  brand         String? // visa, mastercard, etc.
  expiryMonth   Int?
  expiryYear    Int?
  isDefault     Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  user          User @relation(fields: [userId], references: [id])
  
  @@map("payment_methods")
}

model Payment {
  id            String @id @default(uuid())
  orderId       String
  paymentMethodId String?
  amount        Decimal
  currency      String @default("USD")
  status        PaymentStatus @default(PENDING)
  provider      String // stripe, paypal, etc.
  providerId    String // Payment ID from provider
  failureCode   String?
  failureReason String?
  metadata      Json? // Additional provider data
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  order         Order @relation(fields: [orderId], references: [id])
  
  @@map("payments")
}

model Refund {
  id            String @id @default(uuid())
  paymentId     String
  amount        Decimal
  reason        String?
  status        RefundStatus @default(PENDING)
  providerId    String // Refund ID from provider
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("refunds")
}

model Coupon {
  id            String @id @default(uuid())
  code          String @unique
  name          String
  description   String?
  type          CouponType @default(PERCENTAGE)
  value         Decimal
  minimumAmount Decimal?
  maximumDiscount Decimal?
  usageLimit    Int?
  usageCount    Int @default(0)
  isActive      Boolean @default(true)
  startsAt      DateTime
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("coupons")
}

// Authentication Models
model UserSession {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  deviceInfo   Json?    // {userAgent, ip, device, browser, os}
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  lastUsedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  
  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_sessions")
}

model SocialAccount {
  id           String      @id @default(uuid())
  userId       String
  provider     SocialProvider
  providerId   String
  accessToken  String?
  refreshToken String?
  email        String?
  name         String?
  avatar       String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  // Relations
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerId])
  @@map("social_accounts")
}

model UserToken {
  id        String      @id @default(uuid())
  userId    String
  token     String      @unique
  type      TokenType
  purpose   String?
  expiresAt DateTime
  usedAt    DateTime?
  metadata  Json?
  createdAt DateTime    @default(now())
  
  // Relations
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_tokens")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  addedAt   DateTime @default(now())
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([userId, productId])
  @@map("wishlist_items")
}

// Authentication Enums
enum SocialProvider {
  GOOGLE
  FACEBOOK
  APPLE
  TWITTER
  LINKEDIN
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR
  ACCOUNT_VERIFICATION
  PHONE_VERIFICATION
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
  SUPER_ADMIN
}

// Enums
enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CartStatus {
  ACTIVE
  ABANDONED
  CONVERTED
}

enum AddressType {
  SHIPPING
  BILLING
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethodType {
  CARD
  BANK_ACCOUNT
  DIGITAL_WALLET
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

// Admin User Management
model AdminUser {
  id                String @id @default(uuid())
  email             String @unique
  name              String
  password          String
  roleId            String
  isActive          Boolean @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  role              AdminRole @relation(fields: [roleId], references: [id])
  auditLogs         AuditLog[]
  securityEvents    SecurityEvent[]
  securityAudits    SecurityAudit[]
  securityPolicies  SecurityPolicy[]
  dataSubjectRequests DataSubjectRequest[]
  dataBreaches      DataBreach[]
  securityScans     SecurityScan[]
  securityCompliance SecurityCompliance[]
  securityTraining  SecurityTraining[]
  
  @@map("admin_users")
}

model AdminRole {
  id                String @id @default(uuid())
  name              String @unique
  description       String?
  permissions       Json // Array of permission strings
  isSystem          Boolean @default(false) // System roles cannot be deleted
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  users             AdminUser[]
  
  @@map("admin_roles")
}

model AuditLog {
  id                String @id @default(uuid())
  adminUserId       String?
  userId            String? // For customer actions
  action            String // CREATE, UPDATE, DELETE, LOGIN, etc.
  resourceType      String // PRODUCT, ORDER, USER, etc.
  resourceId        String?
  oldValues         Json? // Previous state
  newValues         Json? // New state
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
  
  // Relations
  adminUser         AdminUser? @relation(fields: [adminUserId], references: [id])
  
  @@map("audit_logs")
}

// Enhanced Product Management
model ProductVariant {
  id                String @id @default(uuid())
  productId         String
  sku               String @unique
  name              String
  price             Decimal
  comparePrice      Decimal?
  cost              Decimal?
  weight            Decimal?
  image             String?
  position          Int @default(0)
  trackInventory    Boolean @default(true)
  stock             Int @default(0)
  lowStockThreshold Int @default(10)
  attributes        Json // {color: "red", size: "L"}
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  product           Product @relation(fields: [productId], references: [id])
  inventoryLogs     InventoryLog[]
  
  @@unique([productId, sku])
  @@map("product_variants")
}

model InventoryLog {
  id                String @id @default(uuid())
  productVariantId  String
  type              InventoryLogType
  quantity          Int // Positive for stock in, negative for stock out
  reason            String? // Manual adjustment, sale, return, etc.
  referenceId       String? // Order ID, purchase order, etc.
  notes             String?
  createdBy         String? // Admin user ID
  createdAt         DateTime @default(now())
  
  // Relations
  productVariant    ProductVariant @relation(fields: [productVariantId], references: [id])
  
  @@map("inventory_logs")
}

// Enhanced Category Management
model CategorySEO {
  id                String @id @default(uuid())
  categoryId        String @unique
  metaTitle         String?
  metaDescription   String?
  metaKeywords      String?
  ogTitle           String?
  ogDescription     String?
  ogImage           String?
  canonicalUrl      String?
  robots            String? // noindex, nofollow, etc.
  structuredData    Json? // Schema.org data
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  category          Category @relation(fields: [categoryId], references: [id])
  
  @@map("category_seo")
}

// Tax Management
model TaxZone {
  id                String @id @default(uuid())
  name              String
  code              String @unique
  countries         Json[] // Array of country codes
  provinces         Json[] // Array of {country, province} objects
  postalCodes       Json[] // Array of postal code patterns
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  rates             TaxRate[]
  
  @@map("tax_zones")
}

model TaxRate {
  id                String @id @default(uuid())
  taxZoneId         String
  name              String
  rate              Decimal // Percentage (e.g., 8.25 for 8.25%)
  type              TaxRateType
  appliesTo         Json? // Product categories, specific products, etc.
  isValid           Boolean @default(true)
  validFrom         DateTime
  validTo           DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  taxZone           TaxZone @relation(fields: [taxZoneId], references: [id])
  
  @@map("tax_rates")
}

// Shipping Management
model ShippingZone {
  id                String @id @default(uuid())
  name              String
  countries         Json[] // Array of country codes
  provinces         Json[] // Array of {country, province} objects
  postalCodes       Json[] // Array of postal code patterns
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  rates             ShippingRate[]
  
  @@map("shipping_zones")
}

model ShippingRate {
  id                String @id @default(uuid())
  shippingZoneId    String
  name              String
  description       String?
  code              String @unique
  price             Decimal
  freeOverAmount    Decimal? // Free shipping over this amount
  deliveryTime      String? // "2-3 business days"
  maxWeight         Decimal? // Maximum weight limit
  maxDimensions     Json? // {length, width, height}
  isActive          Boolean @default(true)
  sortOrder         Int @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  shippingZone      ShippingZone @relation(fields: [shippingZoneId], references: [id])
  
  @@map("shipping_rates")
}

// Enhanced Discount System
model Promotion {
  id                String @id @default(uuid())
  name              String
  description       String?
  type              PromotionType
  value             Decimal
  minimumAmount     Decimal?
  maximumDiscount   Decimal?
  usageLimit        Int?
  usageLimitPerUser Int?
  usageCount        Int @default(0)
  isActive          Boolean @default(true)
  startsAt          DateTime
  endsAt            DateTime?
  applicableProducts Json? // Array of product IDs
  applicableCategories Json? // Array of category IDs
  excludedProducts  Json? // Array of product IDs
  excludedCategories Json? // Array of category IDs
  autoApply         Boolean @default(false)
  priority          Int @default(0) // Higher priority applied first
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  codes             DiscountCode[]
  usage             PromotionUsage[]
  
  @@map("promotions")
}

model DiscountCode {
  id                String @id @default(uuid())
  promotionId       String
  code              String @unique
  usageLimit        Int?
  usageCount        Int @default(0)
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  promotion         Promotion @relation(fields: [promotionId], references: [id])
  usage             PromotionUsage[]
  
  @@map("discount_codes")
}

model PromotionUsage {
  id                String @id @default(uuid())
  promotionId       String?
  discountCodeId    String?
  orderId           String
  userId            String?
  discountAmount    Decimal
  createdAt         DateTime @default(now())
  
  // Relations
  promotion         Promotion? @relation(fields: [promotionId], references: [id])
  discountCode      DiscountCode? @relation(fields: [discountCodeId], references: [id])
  order             Order @relation(fields: [orderId], references: [id])
  user              User? @relation(fields: [userId], references: [id])
  
  @@map("promotion_usage")
}

// Analytics and Reports
model SalesReport {
  id                String @id @default(uuid())
  date              DateTime
  totalOrders       Int @default(0)
  totalRevenue      Decimal @default(0)
  totalTax          Decimal @default(0)
  totalShipping     Decimal @default(0)
  totalDiscount     Decimal @default(0)
  averageOrderValue Decimal @default(0)
  conversionRate    Decimal @default(0)
  uniqueVisitors    Int @default(0)
  pageViews         Int @default(0)
  createdAt         DateTime @default(now())
  
  @@unique([date])
  @@map("sales_reports")
}

model ProductAnalytics {
  id                String @id @default(uuid())
  productId         String
  date              DateTime
  views             Int @default(0)
  addToCarts        Int @default(0)
  purchases         Int @default(0)
  revenue           Decimal @default(0)
  conversionRate    Decimal @default(0)
  createdAt         DateTime @default(now())
  
  @@unique([productId, date])
  @@map("product_analytics")
}

// System Settings
model SystemSetting {
  id                String @id @default(uuid())
  key               String @unique
  value             Json
  description       String?
  category          String @default("general")
  isPublic          Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("system_settings")
}

// Enhanced Order Management
model OrderStatusHistory {
  id                String @id @default(uuid())
  orderId           String
  status            OrderStatus
  notes             String?
  notifyCustomer    Boolean @default(false)
  createdBy         String? // Admin user ID
  createdAt         DateTime @default(now())
  
  @@map("order_status_history")
}

model OrderNote {
  id                String @id @default(uuid())
  orderId           String
  content           String
  isInternal        Boolean @default(true) // Internal notes not visible to customer
  createdBy         String? // Admin user ID
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("order_notes")
}

// Invoice Management
model Invoice {
  id                String @id @default(uuid())
  orderId           String @unique
  invoiceNumber     String @unique
  status            InvoiceStatus @default(DRAFT)
  issuedAt          DateTime?
  dueAt             DateTime?
  paidAt            DateTime?
  subtotal          Decimal
  taxAmount         Decimal
  total             Decimal
  notes             String?
  pdfPath           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("invoices")
}

// Bulk Operations
model BulkOperation {
  id                String @id @default(uuid())
  type              BulkOperationType
  status            BulkOperationStatus @default(PENDING)
  totalItems        Int @default(0)
  processedItems    Int @default(0)
  failedItems       Int @default(0)
  filePath          String?
  errors            Json?
  startedAt         DateTime?
  completedAt       DateTime?
  createdBy         String? // Admin user ID
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("bulk_operations")
}

// Additional Enums
enum InventoryLogType {
  MANUAL_ADJUSTMENT
  SALE
  RETURN
  PURCHASE
  TRANSFER
  DAMAGE
  LOSS
}

enum TaxRateType {
  STANDARD
  REDUCED
  ZERO
  EXEMPT
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
  BULK_DISCOUNT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum BulkOperationType {
  PRODUCT_IMPORT
  PRODUCT_EXPORT
  PRODUCT_UPDATE
  CUSTOMER_EXPORT
  ORDER_EXPORT
  INVENTORY_UPDATE
}

enum BulkOperationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// Marketing & Automation Models
model Campaign {
  id                String @id @default(uuid())
  name              String
  description       String?
  type              CampaignType
  status            CampaignStatus @default(DRAFT)
  templateId        String?
  segmentId         String?
  scheduledAt       DateTime?
  sentAt            DateTime?
  completedAt       DateTime?
  totalRecipients   Int @default(0)
  sentCount         Int @default(0)
  deliveredCount    Int @default(0)
  openedCount       Int @default(0)
  clickedCount      Int @default(0)
  convertedCount    Int @default(0)
  settings          Json? // Campaign-specific settings
  createdBy         String? // Admin user ID
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  template          MarketingTemplate? @relation(fields: [templateId], references: [id])
  segment           CustomerSegment? @relation(fields: [segmentId], references: [id])
  interactions      CampaignInteraction[]
  analytics         CampaignAnalytics[]
  
  @@map("campaigns")
}

model MarketingTemplate {
  id                String @id @default(uuid())
  name              String
  type              TemplateType
  subject           String?
  content           String
  variables         Json? // Template variables schema
  styles            Json? // CSS styles for email templates
  isActive          Boolean @default(true)
  createdBy         String? // Admin user ID
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  campaigns          Campaign[]
  
  @@map("marketing_templates")
}

model CustomerSegment {
  id                String @id @default(uuid())
  name              String
  description       String?
  rules             Json // Segmentation rules
  customerCount     Int @default(0)
  isActive          Boolean @default(true)
  isDynamic         Boolean @default(true) // Dynamic vs static segment
  lastSyncedAt      DateTime?
  createdBy         String? // Admin user ID
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  campaigns         Campaign[]
  customers         CustomerSegmentMembership[]
  
  @@map("customer_segments")
}

model CustomerSegmentMembership {
  id                String @id @default(uuid())
  segmentId         String
  customerId        String
  addedAt           DateTime @default(now())
  
  // Relations
  segment           CustomerSegment @relation(fields: [segmentId], references: [id])
  
  @@unique([segmentId, customerId])
  @@map("customer_segment_memberships")
}

model CampaignInteraction {
  id                String @id @default(uuid())
  campaignId        String
  customerId        String?
  type              InteractionType
  data              Json? // Additional interaction data
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
  
  // Relations
  campaign          Campaign @relation(fields: [campaignId], references: [id])
  
  @@map("campaign_interactions")
}

model CampaignAnalytics {
  id                String @id @default(uuid())
  campaignId        String
  date              DateTime
  metric            String // sent, delivered, opened, clicked, converted, bounced
  value             Int @default(0)
  revenue           Decimal @default(0)
  createdAt         DateTime @default(now())
  
  // Relations
  campaign          Campaign @relation(fields: [campaignId], references: [id])
  
  @@unique([campaignId, date, metric])
  @@map("campaign_analytics")
}

model AbandonedCart {
  id                String @id @default(uuid())
  customerId        String?
  sessionId         String?
  email             String?
  phone             String?
  cartData          Json // Cart snapshot
  totalValue        Decimal
  recoveryEmailSent Boolean @default(false)
  recoverySmsSent   Boolean @default(false)
  recoveryCount     Int @default(0)
  recoveredAt       DateTime?
  expiresAt         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("abandoned_carts")
}

model Subscription {
  id                String @id @default(uuid())
  customerId        String?
  email             String?
  phone             String?
  emailSubscribed   Boolean @default(true)
  smsSubscribed     Boolean @default(false)
  preferences       Json? // Subscription preferences
  source            String? // Where they subscribed (newsletter, checkout, etc.)
  doubleOptIn       Boolean @default(false)
  verifiedAt        DateTime?
  unsubscribedAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("subscriptions")
}

model MarketingJob {
  id                String @id @default(uuid())
  type              JobType
  status            JobStatus @default(PENDING)
  priority          JobPriority @default(NORMAL)
  data              Json // Job data
  attempts          Int @default(0)
  maxAttempts       Int @default(3)
  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  error             String?
  result            Json? // Job result
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("marketing_jobs")
}

// Marketing Enums
enum CampaignType {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
  COMPLETED
}

enum TemplateType {
  EMAIL
  SMS
  PUSH
}

enum InteractionType {
  SENT
  DELIVERED
  OPENED
  CLICKED
  CONVERTED
  BOUNCED
  UNSUBSCRIBED
  COMPLAINED
}

enum JobType {
  SEND_EMAIL
  SEND_SMS
  SEND_PUSH
  PROCESS_ABANDONED_CART
  SYNC_SEGMENT
  GENERATE_REPORT
  UPDATE_ANALYTICS
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

// Multi-Vendor Marketplace Models

model Vendor {
  id                    String @id @default(uuid())
  userId                String @unique
  businessName          String
  businessEmail         String
  businessPhone         String?
  businessDescription   String?
  businessAddress       Json? // {street, city, province, country, postalCode}
  taxId                 String?
  websiteUrl            String?
  logoUrl               String?
  bannerUrl             String?
  verificationStatus    VendorVerificationStatus @default(PENDING)
  verificationDocuments Json? // Array of document URLs and metadata
  stripeConnectId       String?
  commissionRate        Decimal @default(10.00)
  rating                Decimal @default(0.00)
  totalReviews          Int @default(0)
  totalSales            Decimal @default(0.00)
  isActive              Boolean @default(false)
  settings              Json? // Vendor-specific settings
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  user                  User @relation(fields: [userId], references: [id])
  products              Product[] @relation("VendorProducts")
  vendorProducts        VendorProduct[]
  vendorOrders          VendorOrder[]
  vendorPayouts         VendorPayout[]
  vendorReviews         VendorReview[]
  vendorCategories      VendorCategory[]
  vendorNotifications   VendorNotification[]
  
  @@map("vendors")
}

model VendorProduct {
  id                    String @id @default(uuid())
  vendorId              String
  productId             String
  sku                   String @unique
  costPrice             Decimal?
  commissionRate        Decimal?
  inventoryCount        Int @default(0)
  reorderLevel          Int @default(0)
  approvalStatus        ProductApprovalStatus @default(PENDING)
  rejectionReason       String?
  isFeatured            Boolean @default(false)
  vendorNotes           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  vendor                Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product               Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendorOrderItems      VendorOrderItem[]
  
  @@unique([vendorId, productId])
  @@map("vendor_products")
}

model VendorOrder {
  id                    String @id @default(uuid())
  orderId               String
  vendorId              String
  vendorOrderNumber     String @unique
  status                VendorOrderStatus @default(PENDING)
  subtotal              Decimal
  commissionAmount      Decimal
  vendorEarnings        Decimal
  shippingCost          Decimal @default(0.00)
  taxAmount             Decimal @default(0.00)
  trackingNumber        String?
  carrier               String?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  order                 Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendor                Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  items                 VendorOrderItem[]
  
  @@map("vendor_orders")
}

model VendorOrderItem {
  id                    String @id @default(uuid())
  vendorOrderId         String
  vendorProductId       String
  quantity              Int
  unitPrice             Decimal
  totalPrice            Decimal
  createdAt             DateTime @default(now())
  
  // Relations
  vendorOrder           VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  vendorProduct         VendorProduct @relation(fields: [vendorProductId], references: [id], onDelete: Cascade)
  
  @@map("vendor_order_items")
}

model VendorPayout {
  id                    String @id @default(uuid())
  vendorId              String
  payoutReference       String @unique
  amount                Decimal
  status                PayoutStatus @default(PENDING)
  stripeTransferId      String?
  periodStart           DateTime
  periodEnd             DateTime
  orderCount            Int @default(0)
  commissionTotal       Decimal @default(0.00)
  processingFee         Decimal @default(0.00)
  createdAt             DateTime @default(now())
  processedAt           DateTime?
  
  // Relations
  vendor                Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  @@map("vendor_payouts")
}

model VendorReview {
  id                    String @id @default(uuid())
  vendorId              String
  userId                String?
  orderId               String?
  rating                Int // 1-5
  title                 String?
  comment               String?
  response              String?
  responseDate          DateTime?
  isVerifiedPurchase    Boolean @default(false)
  helpfulCount          Int @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  vendor                Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  @@map("vendor_reviews")
}

model VendorCategory {
  id                    String @id @default(uuid())
  vendorId              String
  categoryId            String
  isApproved            Boolean @default(false)
  approvalDate          DateTime?
  createdAt             DateTime @default(now())
  
  // Relations
  vendor                Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  @@unique([vendorId, categoryId])
  @@map("vendor_categories")
}

model CommissionTier {
  id                    String @id @default(uuid())
  name                  String
  minMonthlySales       Decimal
  maxMonthlySales       Decimal?
  commissionRate        Decimal
  isActive              Boolean @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("commission_tiers")
}

model VendorNotification {
  id                    String @id @default(uuid())
  vendorId              String
  type                  VendorNotificationType
  title                 String
  message               String
  data                  Json?
  isRead                Boolean @default(false)
  actionUrl             String?
  createdAt             DateTime @default(now())
  readAt                DateTime?
  
  // Relations
  vendor                Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  @@map("vendor_notifications")
}

// Multi-Vendor Enums

enum VendorVerificationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ProductApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VendorOrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum VendorNotificationType {
  ORDER
  PAYMENT
  REVIEW
  SYSTEM
  MARKETING
}

// ============================================
// PHASE 7: ADVANCED COMMERCE FEATURES
// ============================================

// Subscription Management Models

model SubscriptionPlan {
  id          String @id @default(uuid())
  name        String
  slug        String @unique
  description String?
  price       Decimal
  billingCycle String @default("monthly") // monthly, quarterly, annual
  trialDays   Int @default(0)
  setupFee    Decimal @default(0.00)
  isActive    Boolean @default(true)
  sortOrder   Int @default(0)
  features    Json @default("{}")
  metadata    Json @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  subscriptions CustomerSubscription[]
  
  @@map("subscription_plans")
}

model CustomerSubscription {
  id                    String @id @default(uuid())
  userId                String
  planId                String
  status                String @default("pending") // pending, active, paused, cancelled, expired, past_due
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  trialStart            DateTime?
  trialEnd              DateTime?
  cancelledAt           DateTime?
  endsAt                DateTime?
  pauseStartsAt         DateTime?
  quantity              Int @default(1)
  stripeSubscriptionId  String? @unique
  stripeCustomerId      String?
  metadata              Json @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  items     SubscriptionItem[]
  billing   SubscriptionBilling[]
  
  @@map("customer_subscriptions")
}

model SubscriptionItem {
  id            String @id @default(uuid())
  subscriptionId String
  productId     String
  quantity      Int @default(1)
  price         Decimal
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  subscription  CustomerSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id])
  
  @@unique([subscriptionId, productId])
  @@map("subscription_items")
}

model SubscriptionBilling {
  id                    String @id @default(uuid())
  subscriptionId        String
  amount                Decimal
  currency              String @default("USD")
  status                String @default("pending") // pending, paid, failed, refunded, void
  stripeInvoiceId       String? @unique
  stripeChargeId        String?
  billingPeriodStart    DateTime
  billingPeriodEnd      DateTime
  attemptCount          Int @default(0)
  nextAttemptAt         DateTime?
  paidAt                DateTime?
  failureReason         String?
  metadata              Json @default("{}")
  createdAt             DateTime @default(now())
  
  // Relations
  subscription  CustomerSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  @@map("subscription_billing")
}

// Loyalty Program Models

model LoyaltyProgram {
  id                    String @id @default(uuid())
  name                  String @default("Default Loyalty Program")
  pointsPerDollar       Decimal @default(1.00)
  pointsExpirationDays  Int @default(365)
  minimumPurchaseAmount Decimal @default(1.00)
  isActive              Boolean @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("loyalty_program")
}

model LoyaltyTier {
  id                    String @id @default(uuid())
  name                  String
  slug                  String @unique
  minSpending           Decimal @default(0)
  minPoints             Int @default(0)
  pointsMultiplier      Decimal @default(1.00)
  discountPercent       Decimal @default(0.00)
  freeShipping          Boolean @default(false)
  freeShippingMinOrder  Decimal @default(0.00)
  exclusiveAccess       Boolean @default(false)
  birthdayBonusPoints   Int @default(0)
  anniversaryBonusPoints Int @default(0)
  benefits              Json @default("{}")
  color                 String @default("#6B7280")
  icon                  String?
  sortOrder             Int
  isActive              Boolean @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  customers             CustomerLoyalty[]
  loyaltyRewards        LoyaltyReward[]
  
  @@map("loyalty_tiers")
}

model CustomerLoyalty {
  id                    String @id @default(uuid())
  userId                String @unique
  tierId                String
  pointsBalance         Int @default(0)
  lifetimePoints        Int @default(0)
  totalSpending         Decimal @default(0.00)
  tierAdvancementAt     DateTime?
  lastActivityAt        DateTime @default(now())
  birthday              DateTime?
  anniversary            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  user                  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier                  LoyaltyTier @relation(fields: [tierId], references: [id])
  pointsTransactions    PointsTransaction[]
  pointsRedemptions     PointsRedemption[]
  
  @@map("customer_loyalty")
}

model PointsTransaction {
  id            String @id @default(uuid())
  userId        String
  points        Int // Positive for earned, negative for redeemed
  type          String // purchase, redemption, referral, bonus, expiration, adjustment, signup, birthday, review
  referenceId   String?
  referenceType String?
  description   String?
  expiresAt     DateTime?
  metadata      Json @default("{}")
  createdAt     DateTime @default(now())
  
  // Relations
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerLoyalty CustomerLoyalty @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("points_transactions")
}

model LoyaltyReward {
  id            String @id @default(uuid())
  name          String
  description   String?
  type          String // discount, free_product, free_shipping, exclusive_access, voucher
  pointsCost    Int
  value         Decimal?
  discountType  String? // fixed, percentage
  productId     String?
  inventory     Int @default(-1) // -1 for unlimited
  minTierId     String?
  isActive      Boolean @default(true)
  startsAt      DateTime @default(now())
  endsAt        DateTime?
  imageUrl      String?
  termsConditions String?
  metadata      Json @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  product       Product? @relation(fields: [productId], references: [id])
  minTier       LoyaltyTier? @relation(fields: [minTierId], references: [id])
  pointsRedemptions PointsRedemption[]
  
  @@map("loyalty_rewards")
}

model PointsRedemption {
  id            String @id @default(uuid())
  userId        String
  rewardId      String
  pointsUsed    Int
  status        String @default("pending") // pending, confirmed, used, expired, cancelled
  orderId       String?
  voucherCode   String? @unique
  usedAt        DateTime?
  expiresAt     DateTime
  metadata      Json @default("{}")
  createdAt     DateTime @default(now())
  
  // Relations
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerLoyalty CustomerLoyalty @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward        LoyaltyReward @relation(fields: [rewardId], references: [id])
  
  @@map("points_redemptions")
}

// Affiliate Program Models

model Affiliate {
  id                    String @id @default(uuid())
  userId                String @unique
  companyName           String?
  websiteUrl            String?
  bio                   String?
  status                String @default("pending") // pending, approved, rejected, suspended
  commissionTierId      String?
  stripeAccountId       String? @unique
  taxInfo               Json @default("{}")
  marketingMethods      Json @default("[]")
  targetAudience        String?
  approvalNotes         String?
  rejectionReason       String?
  approvedAt            DateTime?
  suspendedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  user                  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  commissionTier        AffiliateCommissionTier? @relation(fields: [commissionTierId], references: [id])
  links                 AffiliateLink[]
  commissions           AffiliateCommission[]
  payouts               AffiliatePayout[]
  clicks                AffiliateClick[]
  
  @@map("affiliates")
}

model AffiliateCommissionTier {
  id                String @id @default(uuid())
  name              String
  slug              String @unique
  minSales          Decimal @default(0)
  minOrders         Int @default(0)
  commissionRate    Decimal
  recurringRate     Decimal @default(0.00)
  bonusRate         Decimal @default(0.00)
  cookieDuration    Int @default(30) // Days
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  affiliates        Affiliate[]
  
  @@map("affiliate_commission_tiers")
}

model AffiliateLink {
  id            String @id @default(uuid())
  affiliateId   String
  name          String
  url           String
  slug          String @unique
  productId     String?
  categoryId    String?
  campaignName  String?
  isActive      Boolean @default(true)
  trackConversions Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  affiliate     Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  product       Product? @relation(fields: [productId], references: [id])
  clicks        AffiliateClick[]
  
  @@map("affiliate_links")
}

model AffiliateClick {
  id            String @id @default(uuid())
  affiliateId   String
  linkId        String
  ipAddress     String?
  userAgent     String?
  referrer      String?
  landingPage   String?
  countryCode   String?
  deviceType    String?
  browser       String?
  converted     Boolean @default(false)
  conversionValue Decimal?
  conversionDate DateTime?
  orderId       String?
  createdAt     DateTime @default(now())
  
  // Relations
  affiliate     Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  link          AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  commissions   AffiliateCommission[]
  
  @@map("affiliate_clicks")
}

model AffiliateCommission {
  id                String @id @default(uuid())
  affiliateId       String
  orderId           String?
  clickId           String?
  amount            Decimal
  commissionRate    Decimal
  commissionAmount  Decimal
  type              String @default("standard") // standard, recurring, bonus, tier_bonus
  status            String @default("pending") // pending, approved, paid, reversed, void
  payoutId          String?
  approvedAt        DateTime?
  paidAt            DateTime?
  reversedAt        DateTime?
  notes             String?
  metadata          Json @default("{}")
  createdAt         DateTime @default(now())
  
  // Relations
  affiliate         Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  click             AffiliateClick? @relation(fields: [clickId], references: [id])
  payout            AffiliatePayout? @relation(fields: [payoutId], references: [id])
  
  @@map("affiliate_commissions")
}

model AffiliatePayout {
  id                String @id @default(uuid())
  affiliateId       String
  totalAmount       Decimal
  commissionCount   Int
  status            String @default("pending") // pending, processing, paid, failed, cancelled
  stripeTransferId  String? @unique
  paymentMethod     String @default("stripe")
  processingFee     Decimal @default(0.00)
  netAmount         Decimal
  currency          String @default("USD")
  paidAt            DateTime?
  failedAt          DateTime?
  failureReason     String?
  notes             String?
  createdAt         DateTime @default(now())
  
  // Relations
  affiliate         Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  commissions       AffiliateCommission[]
  
  @@map("affiliate_payouts")
}

// ============================================
// PHASE 8: SECURITY, COMPLIANCE & HARDENING
// ============================================

// Security & Authentication Models

model SecuritySession {
  id                    String @id @default(uuid())
  userId                String
  sessionId             String @unique
  token                 String @unique
  refreshToken          String? @unique
  deviceFingerprint     String?
  ipAddress             String
  userAgent             String?
  location              Json? // {country, city, coordinates}
  isActive              Boolean @default(true)
  lastActivityAt        DateTime @default(now())
  expiresAt             DateTime
  mfaVerified           Boolean @default(false)
  mfaMethod             String? // totp, sms, email
  riskScore             Decimal @default(0.00)
  securityFlags         Json @default("[]") // Array of security flags
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  user                  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  securityEvents        SecurityEvent[]
  
  @@map("security_sessions")
}

model SecurityEvent {
  id                    String @id @default(uuid())
  sessionId             String?
  userId                String?
  adminUserId           String?
  type                  SecurityEventType
  severity              SecuritySeverity @default(LOW)
  description           String
  details               Json? // Additional event details
  ipAddress             String?
  userAgent             String?
  resourceType          String? // USER, ORDER, PRODUCT, etc.
  resourceId            String?
  outcome               SecurityEventOutcome @default(UNKNOWN)
  mitigations          Json? // Applied mitigations
  isResolved            Boolean @default(false)
  resolvedAt            DateTime?
  resolvedBy            String? // Admin user ID
  createdAt             DateTime @default(now())
  
  // Relations
  session               SecuritySession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@map("security_events")
}

model MfaDevice {
  id                    String @id @default(uuid())
  userId                String
  type                  MfaDeviceType
  name                  String? // Device name (e.g., "iPhone 13", "Google Authenticator")
  secret                String // Encrypted secret
  backupCodes           Json? // Encrypted backup codes
  isVerified            Boolean @default(false)
  isPrimary             Boolean @default(false)
  lastUsedAt            DateTime?
  ipAddress             String?
  userAgent             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("mfa_devices")
}

model SecurityPolicy {
  id                    String @id @default(uuid())
  name                  String @unique
  type                  SecurityPolicyType
  settings              Json // Policy-specific settings
  isActive              Boolean @default(true)
  priority              Int @default(0)
  appliesTo             Json? // {roles, users, departments}
  schedule              Json? // When policy applies
  createdBy             String? // Admin user ID
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("security_policies")
}

model SecurityAudit {
  id                    String @id @default(uuid())
  entityType            String // USER, ORDER, PRODUCT, etc.
  entityId              String
  action                String // CREATE, UPDATE, DELETE, LOGIN, etc.
  oldValues             Json? // Previous state
  newValues             Json? // New state
  changedFields         Json? // Array of changed field names
  userId                String?
  adminUserId           String?
  sessionId             String?
  ipAddress             String?
  userAgent             String?
  complianceTags        Json? // GDPR, PCI-DSS, etc.
  retentionPeriod       Int? // Days to retain this record
  isArchived            Boolean @default(false)
  archivedAt            DateTime?
  createdAt             DateTime @default(now())
  
  @@map("security_audits")
}

// GDPR & Privacy Models

model DataSubjectRequest {
  id                    String @id @default(uuid())
  requestId              String @unique
  userId                String?
  email                 String
  type                  DsrType
  status                DsrStatus @default(PENDING)
  description           String?
  verificationToken      String?
  verifiedAt            DateTime?
  processedAt           DateTime?
  completedAt           DateTime?
  rejectionReason       String?
  dataExportUrl         String? // For access requests
  deletionSummary       Json? // For deletion requests
  processingNotes       String?
  assignedTo            String? // Admin user ID
  ipAddress             String?
  userAgent             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("data_subject_requests")
}

model ConsentRecord {
  id                    String @id @default(uuid())
  userId                String?
  sessionId             String?
  email                 String?
  type                  ConsentType
  purpose               String // marketing, analytics, essential, etc.
  status                ConsentStatus @default(GRANTED)
  ipAddress             String?
  userAgent             String?
  documentVersion       String? // Privacy policy version
  lawfulBasis          String? // consent, contract, legal_obligation, etc.
  withdrawnAt           DateTime?
  expiresAt             DateTime?
  metadata              Json @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("consent_records")
}

model DataProcessingRecord {
  id                    String @id @default(uuid())
  name                  String
  description           String?
  purpose               String
  legalBasis            String
  dataCategories        Json // Array of data categories
  recipients            Json // Array of data recipients
  retentionPeriod       String // Retention period description
  securityMeasures      Json // Description of security measures
  dpoContact            String? // Data protection officer contact
  isThirdParty          Boolean @default(false)
  thirdPartyCountry     String?
  reviewDate            DateTime?
  isActive              Boolean @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("data_processing_records")
}

model DataBreach {
  id                    String @id @default(uuid())
  incidentId            String @unique
  severity              BreachSeverity
  type                  BreachType
  description           String
  affectedDataTypes     Json // Array of affected data types
  affectedUsersCount    Int @default(0)
  discoveryDate         DateTime
  containmentDate       DateTime?
  notificationDate       DateTime?
  resolutionDate        DateTime?
  rootCause             String?
  impactAssessment      Json?
  remediationActions    Json?
  notifiedAuthorities   Boolean @default(false)
  notifiedIndividuals   Boolean @default(false)
  dpoNotified           Boolean @default(false)
  assignedTo            String? // Admin user ID
  status                BreachStatus @default(INVESTIGATING)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("data_breaches")
}

// PCI-DSS & Payment Security Models

model PaymentCard {
  id                    String @id @default(uuid())
  userId                String
  token                 String @unique // Tokenized card data
  last4                 String
  brand                 String // visa, mastercard, etc.
  expiryMonth           Int
  expiryYear            Int
  cardholderName        String?
  fingerprint           String? // Card fingerprint for deduplication
  isDefault             Boolean @default(false)
  isActive              Boolean @default(true)
  verificationMethod    String? // 3ds, cvv, etc.
  ipAddress             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("payment_cards")
}

model PaymentSecurityEvent {
  id                    String @id @default(uuid())
  transactionId         String?
  paymentMethodId       String?
  userId                String?
  type                  PaymentSecurityEventType
  riskScore             Decimal @default(0.00)
  riskFactors           Json? // Array of risk factors
  action                PaymentSecurityAction // ALLOW, CHALLENGE, BLOCK
  details               Json? // Additional details
  ipAddress             String?
  deviceFingerprint     String?
  createdAt             DateTime @default(now())
  
  @@map("payment_security_events")
}

model SecurityScan {
  id                    String @id @default(uuid())
  type                  ScanType
  target                String // URL, IP, container name, etc.
  status                ScanStatus @default(PENDING)
  scheduledAt           DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  findings              Json? // Scan findings
  summary               Json? // Executive summary
  criticalCount         Int @default(0)
  highCount             Int @default(0)
  mediumCount           Int @default(0)
  lowCount              Int @default(0)
  infoCount             Int @default(0)
  recommendations       Json? // Remediation recommendations
  initiatedBy           String? // Admin user ID or system
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("security_scans")
}

model SecurityCompliance {
  id                    String @id @default(uuid())
  framework             String // GDPR, PCI-DSS, ISO27001, etc.
  requirement           String
  control               String
  status                ComplianceStatus @default(NON_COMPLIANT)
  evidence              Json? // Evidence of compliance
  lastAssessed          DateTime?
  nextAssessment        DateTime?
  assignedTo            String? // Admin user ID
  notes                 String?
  artifacts             Json? // Links to documentation, policies, etc.
  riskLevel             ComplianceRiskLevel @default(MEDIUM)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("security_compliance")
}

model SecurityTraining {
  id                    String @id @default(uuid())
  userId                String?
  adminUserId           String?
  courseName            String
  courseType            TrainingType
  status                TrainingStatus @default(ASSIGNED)
  assignedAt            DateTime @default(now())
  startedAt             DateTime?
  completedAt           DateTime?
  expiresAt             DateTime?
  score                 Int? // Training score
  certificateUrl        String?
  ipAddress             String?
  userAgent             String?
  metadata              Json @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("security_training")
}

// Security Enums

enum SecurityEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  PASSWORD_CHANGE
  PASSWORD_RESET
  MFA_ENABLED
  MFA_DISABLED
  MFA_CHALLENGE
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  SUSPICIOUS_LOGIN
  DATA_ACCESS
  DATA_MODIFICATION
  DATA_EXPORT
  DATA_DELETION
  PRIVILEGE_ESCALATION
  SECURITY_POLICY_VIOLATION
  MALICIOUS_REQUEST
  BRUTE_FORCE_ATTACK
  INJECTION_ATTACK
  XSS_ATTEMPT
  CSRF_ATTEMPT
  SESSION_HIJACK
  UNAUTHORIZED_ACCESS
  API_ABUSE
  RATE_LIMIT_EXCEEDED
  ANOMALOUS_BEHAVIOR
  DEVICE_TRUST_CHANGE
  LOCATION_ANOMALY
}

enum SecuritySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SecurityEventOutcome {
  BLOCKED
  ALLOWED
  CHALLENGED
  UNKNOWN
}

enum MfaDeviceType {
  TOTP
  SMS
  EMAIL
  HARDWARE_TOKEN
  BIOMETRIC
  PUSH_NOTIFICATION
}

enum SecurityPolicyType {
  PASSWORD_POLICY
  SESSION_POLICY
  MFA_POLICY
  ACCESS_POLICY
  DATA_PROTECTION_POLICY
  API_SECURITY_POLICY
  NETWORK_SECURITY_POLICY
}

enum DsrType {
  ACCESS
  DELETION
  PORTABILITY
  RESTRICTION
  OBJECTION
  RECTIFICATION
}

enum DsrStatus {
  PENDING
  VERIFIED
  PROCESSING
  COMPLETED
  REJECTED
  EXPIRED
}

enum ConsentType {
  MARKETING
  ANALYTICS
  ESSENTIAL
  FUNCTIONAL
  ADVERTISING
  PERSONALIZATION
}

enum ConsentStatus {
  GRANTED
  DENIED
  WITHDRAWN
  EXPIRED
}

enum BreachSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BreachType {
  UNAUTHORIZED_ACCESS
  DATA_LEAKAGE
  MALWARE_ATTACK
  PHISHING
  INSIDER_THREAT
  PHYSICAL_THEFT
  DENIAL_OF_SERVICE
  SOCIAL_ENGINEERING
}

enum BreachStatus {
  INVESTIGATING
  CONTAINED
  RESOLVED
  REPORTED
  CLOSED
}

enum PaymentSecurityEventType {
  FRAUD_DETECTED
  SUSPICIOUS_TRANSACTION
  UNUSUAL_SPENDING
  LOCATION_ANOMALY
  DEVICE_ANOMALY
  VELOCITY_CHECK
  BLACKLIST_MATCH
  WHITELIST_BYPASS
}

enum PaymentSecurityAction {
  ALLOW
  CHALLENGE
  BLOCK
  REVIEW
}

enum ScanType {
  VULNERABILITY
  COMPLIANCE
  MALWARE
  CONFIGURATION
  PENETRATION
  CODE_ANALYSIS
  CONTAINER_SCAN
  NETWORK_SCAN
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ComplianceStatus {
  COMPLIANT
  NON_COMPLIANT
  PARTIALLY_COMPLIANT
  NOT_ASSESSED
}

enum ComplianceRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TrainingType {
  SECURITY_AWARENESS
  PHISHING_SIMULATION
  DATA_PROTECTION
  PCI_DSS
  INCIDENT_RESPONSE
  SECURE_CODING
  COMPLIANCE_TRAINING
}

enum TrainingStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  EXPIRED
  FAILED
}
