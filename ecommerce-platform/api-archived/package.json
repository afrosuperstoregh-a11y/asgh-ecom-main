{
    "name": "ecommerce-api",
    "version": "1.0.0",
    "description": "E-commerce API built with Next.js and TypeScript",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:seed": "tsx prisma/seed-simple.ts",
        "prisma:studio": "prisma studio",
        "prisma:reset": "prisma migrate reset",
        "test": "echo \"Error: no test specified\"",
        "start": "node src/index.js",
        "dev": "node src/index.js",
        "setup": "npm run prisma:generate && npm run prisma:migrate && npm run prisma:seed",
        "test:email": "jest test/email/email.service.spec.ts --verbose --runInBand --detectOpenHandles",
        "test:watch:email": "jest test/email/email.service.spec.ts --watch --verbose --runInBand --detectOpenHandles"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "@sendgrid/mail": "^8.1.6",
        "@types/cookie-parser": "^1.4.6",
        "@types/validator": "^13.11.8",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "crypto-js": "^4.1.1",
        "dotenv": "^16.6.1",
        "express": "^4.22.1",
        "express-async-handler": "^1.2.0",
        "express-rate-limit": "^7.5.1",
        "express-validator": "^7.0.1",
        "helmet": "^7.2.0",
        "http-status-codes": "^2.3.0",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "nanoid": "^5.1.6",
        "next": "^14.0.4",
        "objection": "^3.1.5",
        "redis": "^4.7.1",
        "stripe": "^14.5.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0",
        "typesense": "^1.8.2",
        "winston": "^3.19.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.25",
        "@types/jest": "^29.5.11",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^20.19.28",
        "@types/redis": "^4.0.10",
        "@types/supertest": "^2.0.12",
        "@typescript-eslint/eslint-plugin": "^6.18.1",
        "@typescript-eslint/parser": "^6.18.1",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-simple-import-sort": "^10.0.0",
        "jest": "^29.7.0",
        "prettier": "^3.1.1",
        "prisma": "^5.22.0",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.1",
        "ts-node-dev": "^2.0.0",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.6.2",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=18.0.0"
    }
