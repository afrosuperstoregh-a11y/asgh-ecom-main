// This file contains admin-specific schema additions
// Copy these models into your main schema.prisma file

// Admin User Management
model AdminUser {
  id                String @id @default(uuid())
  email             String @unique
  name              String
  password          String
  roleId            String
  isActive          Boolean @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  role              AdminRole @relation(fields: [roleId], references: [id])
  auditLogs         AuditLog[]
  
  @@map("admin_users")
}

model AdminRole {
  id                String @id @default(uuid())
  name              String @unique
  description       String?
  permissions       Json // Array of permission strings
  isSystem          Boolean @default(false) // System roles cannot be deleted
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  users             AdminUser[]
  
  @@map("admin_roles")
}

model AuditLog {
  id                String @id @default(uuid())
  adminUserId       String?
  userId            String? // For customer actions
  action            String // CREATE, UPDATE, DELETE, LOGIN, etc.
  resourceType      String // PRODUCT, ORDER, USER, etc.
  resourceId        String?
  oldValues         Json? // Previous state
  newValues         Json? // New state
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
  
  // Relations
  adminUser         AdminUser? @relation(fields: [adminUserId], references: [id])
  
  @@map("audit_logs")
}

// Enhanced Product Management
model ProductVariant {
  id                String @id @default(uuid())
  productId         String
  sku               String @unique
  name              String
  price             Decimal
  comparePrice      Decimal?
  cost              Decimal?
  weight            Decimal?
  image             String?
  position          Int @default(0)
  trackInventory    Boolean @default(true)
  stock             Int @default(0)
  lowStockThreshold Int @default(10)
  attributes        Json // {color: "red", size: "L"}
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  product           Product @relation(fields: [productId], references: [id])
  inventoryLogs     InventoryLog[]
  
  @@unique([productId, sku])
  @@map("product_variants")
}

model InventoryLog {
  id                String @id @default(uuid())
  productVariantId  String
  type              InventoryLogType
  quantity          Int // Positive for stock in, negative for stock out
  reason            String? // Manual adjustment, sale, return, etc.
  referenceId       String? // Order ID, purchase order, etc.
  notes             String?
  createdBy         String? // Admin user ID
  createdAt         DateTime @default(now())
  
  // Relations
  productVariant    ProductVariant @relation(fields: [productVariantId], references: [id])
  
  @@map("inventory_logs")
}

// Enhanced Category Management
model CategorySEO {
  id                String @id @default(uuid())
  categoryId        String @unique
  metaTitle         String?
  metaDescription   String?
  metaKeywords      String?
  ogTitle           String?
  ogDescription     String?
  ogImage           String?
  canonicalUrl      String?
  robots            String? // noindex, nofollow, etc.
  structuredData    Json? // Schema.org data
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  category          Category @relation(fields: [categoryId], references: [id])
  
  @@map("category_seo")
}

// Tax Management
model TaxZone {
  id                String @id @default(uuid())
  name              String
  code              String @unique
  countries         Json[] // Array of country codes
  provinces         Json[] // Array of {country, province} objects
  postalCodes       Json[] // Array of postal code patterns
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  rates             TaxRate[]
  
  @@map("tax_zones")
}

model TaxRate {
  id                String @id @default(uuid())
  taxZoneId         String
  name              String
  rate              Decimal // Percentage (e.g., 8.25 for 8.25%)
  type              TaxRateType
  appliesTo         Json? // Product categories, specific products, etc.
  isValid           Boolean @default(true)
  validFrom         DateTime
  validTo           DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  taxZone           TaxZone @relation(fields: [taxZoneId], references: [id])
  
  @@map("tax_rates")
}

// Shipping Management
model ShippingZone {
  id                String @id @default(uuid())
  name              String
  countries         Json[] // Array of country codes
  provinces         Json[] // Array of {country, province} objects
  postalCodes       Json[] // Array of postal code patterns
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  rates             ShippingRate[]
  
  @@map("shipping_zones")
}

model ShippingRate {
  id                String @id @default(uuid())
  shippingZoneId    String
  name              String
  description       String?
  code              String @unique
  price             Decimal
  freeOverAmount    Decimal? // Free shipping over this amount
  deliveryTime      String? // "2-3 business days"
  maxWeight         Decimal? // Maximum weight limit
  maxDimensions     Json? // {length, width, height}
  isActive          Boolean @default(true)
  sortOrder         Int @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  shippingZone      ShippingZone @relation(fields: [shippingZoneId], references: [id])
  
  @@map("shipping_rates")
}

// Enhanced Discount System
model Promotion {
  id                String @id @default(uuid())
  name              String
  description       String?
  type              PromotionType
  value             Decimal
  minimumAmount     Decimal?
  maximumDiscount   Decimal?
  usageLimit        Int?
  usageLimitPerUser Int?
  usageCount        Int @default(0)
  isActive          Boolean @default(true)
  startsAt          DateTime
  endsAt            DateTime?
  applicableProducts Json? // Array of product IDs
  applicableCategories Json? // Array of category IDs
  excludedProducts  Json? // Array of product IDs
  excludedCategories Json? // Array of category IDs
  autoApply         Boolean @default(false)
  priority          Int @default(0) // Higher priority applied first
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  codes             DiscountCode[]
  usage             PromotionUsage[]
  
  @@map("promotions")
}

model DiscountCode {
  id                String @id @default(uuid())
  promotionId       String
  code              String @unique
  usageLimit        Int?
  usageCount        Int @default(0)
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  promotion         Promotion @relation(fields: [promotionId], references: [id])
  usage             PromotionUsage[]
  
  @@map("discount_codes")
}

model PromotionUsage {
  id                String @id @default(uuid())
  promotionId       String?
  discountCodeId    String?
  orderId           String
  userId            String?
  discountAmount    Decimal
  createdAt         DateTime @default(now())
  
  // Relations
  promotion         Promotion? @relation(fields: [promotionId], references: [id])
  discountCode      DiscountCode? @relation(fields: [discountCodeId], references: [id])
  order             Order @relation(fields: [orderId], references: [id])
  user              User? @relation(fields: [userId], references: [id])
  
  @@map("promotion_usage")
}

// Analytics and Reports
model SalesReport {
  id                String @id @default(uuid())
  date              DateTime
  totalOrders       Int @default(0)
  totalRevenue      Decimal @default(0)
  totalTax          Decimal @default(0)
  totalShipping     Decimal @default(0)
  totalDiscount     Decimal @default(0)
  averageOrderValue Decimal @default(0)
  conversionRate    Decimal @default(0)
  uniqueVisitors    Int @default(0)
  pageViews         Int @default(0)
  createdAt         DateTime @default(now())
  
  @@unique([date])
  @@map("sales_reports")
}

model ProductAnalytics {
  id                String @id @default(uuid())
  productId         String
  date              DateTime
  views             Int @default(0)
  addToCarts        Int @default(0)
  purchases         Int @default(0)
  revenue           Decimal @default(0)
  conversionRate    Decimal @default(0)
  createdAt         DateTime @default(now())
  
  @@unique([productId, date])
  @@map("product_analytics")
}

// System Settings
model SystemSetting {
  id                String @id @default(uuid())
  key               String @unique
  value             Json
  description       String?
  category          String @default("general")
  isPublic          Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("system_settings")
}

// Enhanced Order Management
model OrderStatusHistory {
  id                String @id @default(uuid())
  orderId           String
  status            OrderStatus
  notes             String?
  notifyCustomer    Boolean @default(false)
  createdBy         String? // Admin user ID
  createdAt         DateTime @default(now())
  
  @@map("order_status_history")
}

model OrderNote {
  id                String @id @default(uuid())
  orderId           String
  content           String
  isInternal        Boolean @default(true) // Internal notes not visible to customer
  createdBy         String? // Admin user ID
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("order_notes")
}

// Invoice Management
model Invoice {
  id                String @id @default(uuid())
  orderId           String @unique
  invoiceNumber     String @unique
  status            InvoiceStatus @default(DRAFT)
  issuedAt          DateTime?
  dueAt             DateTime?
  paidAt            DateTime?
  subtotal          Decimal
  taxAmount         Decimal
  total             Decimal
  notes             String?
  pdfPath           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("invoices")
}

// Bulk Operations
model BulkOperation {
  id                String @id @default(uuid())
  type              BulkOperationType
  status            BulkOperationStatus @default(PENDING)
  totalItems        Int @default(0)
  processedItems    Int @default(0)
  failedItems       Int @default(0)
  filePath          String?
  errors            Json?
  startedAt         DateTime?
  completedAt       DateTime?
  createdBy         String? // Admin user ID
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("bulk_operations")
}

// Enums
enum InventoryLogType {
  MANUAL_ADJUSTMENT
  SALE
  RETURN
  PURCHASE
  TRANSFER
  DAMAGE
  LOSS
}

enum TaxRateType {
  STANDARD
  REDUCED
  ZERO
  EXEMPT
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
  BULK_DISCOUNT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum BulkOperationType {
  PRODUCT_IMPORT
  PRODUCT_EXPORT
  PRODUCT_UPDATE
  CUSTOMER_EXPORT
  ORDER_EXPORT
  INVENTORY_UPDATE
}

enum BulkOperationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}
