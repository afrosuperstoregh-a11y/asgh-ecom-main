# Frontend Development Environment

# Frontend Environment Variables
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (if needed for frontend)
NEXT_PUBLIC_DB_HOST=localhost
NEXT_PUBLIC_DB_PORT=5432
NEXT_PUBLIC_DB_NAME=ecommerce_db
NEXT_PUBLIC_DB_USER=postgres
NEXT_PUBLIC_DB_PASSWORD=password

# Stripe (if needed for payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Google Analytics (if needed)
NEXT_PUBLIC_GA_ID=GA_MEASUREMENT_ID

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_CHAT=false
NEXT_PUBLIC_ENABLE_REVIEWS=true

# Image Optimization
NEXT_PUBLIC_IMAGE_DOMAINS=images.unsplash.com,images.pexels.com
NEXT_PUBLIC_IMAGE_LOADER=custom

# Development Settings
NEXT_PUBLIC_DEV_MODE=true
NEXT_PUBLIC_DEBUG_MODE=false
