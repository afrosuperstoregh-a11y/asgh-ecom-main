# ============================================
# PHASE 8: SECURITY, COMPLIANCE & HARDENING
# Environment Configuration
# ============================================

# Application Environment
NODE_ENV=production
APP_NAME=E-Commerce Platform
APP_VERSION=8.0.0
APP_URL=https://your-domain.com
API_URL=https://api.your-domain.com

# Security Database Configuration
SECURITY_DATABASE_NAME=ecommerce_security
SECURITY_DATABASE_USER=security_user
SECURITY_DATABASE_PASSWORD=your_secure_database_password_here
SECURITY_DB_PORT=5433
SECURITY_DB_SSL_MODE=require
SECURITY_DB_SSL_CERT=/app/certs/db-cert.pem
SECURITY_DB_SSL_KEY=/app/certs/db-key.pem
SECURITY_DB_SSL_CA=/app/certs/db-ca.pem

# Redis Security Configuration
REDIS_SECURITY_PASSWORD=your_secure_redis_password_here
REDIS_SECURITY_PORT=6380
REDIS_SECURITY_DB=0
REDIS_SECURITY_TLS=true
REDIS_SECURITY_CERT=/app/certs/redis-cert.pem
REDIS_SECURITY_KEY=/app/certs/redis-key.pem
REDIS_SECURITY_CA=/app/certs/redis-ca.pem

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_minimum_256_bits_long
JWT_REFRESH_SECRET=your_super_secure_jwt_refresh_secret_minimum_256_bits_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=ecommerce-platform
JWT_AUDIENCE=ecommerce-users

# Encryption Configuration
ENCRYPTION_KEY=your_32_character_encryption_key_here
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_IV_LENGTH=16
ENCRYPTION_TAG_LENGTH=16
API_KEY_ENCRYPTION_KEY=your_api_key_encryption_key_32_chars

# Multi-Factor Authentication
MFA_SECRET_KEY=your_mfa_secret_key_minimum_32_characters
MFA_ISSUER=E-Commerce Platform
MFA_DIGITS=6
MFA_WINDOW=1
MFA_BACKUP_CODES_COUNT=10

# Session Configuration
SESSION_SECRET=your_session_secret_minimum_32_characters
SESSION_NAME=ecommerce-session
SESSION_MAX_AGE=86400000
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
RATE_LIMIT_SKIP_FAILED_REQUESTS=false
RATE_LIMIT_SKIP_HEALTH_CHECK=true

# CORS Configuration
CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# Web Application Firewall (WAF)
WAF_ENABLED=true
WAF_MODE=blocking
WAF_PARANOIA_LEVEL=2
WAF_ANOMALY_THRESHOLD=5
WAF_INBOUND_ANOMALY_THRESHOLD=5
WAF_OUTBOUND_ANOMALY_THRESHOLD=4

# Security Headers
SECURITY_HEADERS_ENABLED=true
HELMET_CONTENT_SECURITY_POLICY=true
HELMET_CROSS_ORIGIN_EMBEDDER_POLICY=true
HELMET_CROSS_ORIGIN_OPENER_POLICY=true
HELMET_CROSS_ORIGIN_RESOURCE_POLICY=true
HELMET_DNS_PREFETCH_CONTROL=true
HELMET_FRAME_OPTIONS=SAMEORIGIN
HELMET_HIDE_POWERED_BY=true
HELMET_HSTS_MAX_AGE=31536000
HELMET_HSTS_INCLUDE_SUBDOMAINS=true
HELMET_HSTS_PRELOAD=true
HELMET_IE_NO_OPEN=true
HELMET_NO_SNIFF=true
HELMET_ORIGIN_AGENT_CLUSTER=true
HELMET_PERMITTED_CROSS_DOMAIN_POLICIES=false
HELMET_REFERRER_POLICY=strict-origin-when-cross-origin
HELMET_XSS_PROTECTION=true

# SSL/TLS Configuration
SSL_CERT_PATH=/app/certs/server.crt
SSL_KEY_PATH=/app/certs/server.key
SSL_CA_PATH=/app/certs/ca.crt
SSL_PROTOCOLS=TLSv1.2,TLSv1.3
SSL_CIPHERS=ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305
SSL_PREFER_SERVER_CIPHERS=true
SSL_SESSION_TIMEOUT=5m
SSL_SESSION_CACHE_SHARED=SSL:10m

# Logging Configuration
SECURITY_LOG_LEVEL=info
SECURITY_LOG_FORMAT=json
SECURITY_LOG_FILE=/app/logs/security.log
SECURITY_LOG_MAX_SIZE=100m
SECURITY_LOG_MAX_FILES=10
SECURITY_AUDIT_LOG_ENABLED=true
SECURITY_AUDIT_LOG_FILE=/app/logs/audit.log
SECURITY_ACCESS_LOG_ENABLED=true
SECURITY_ACCESS_LOG_FILE=/app/logs/access.log

# Monitoring Configuration
ELASTICSEARCH_SECURITY_PASSWORD=your_elasticsearch_password
ELASTICSEARCH_SECURITY_PORT=9201
KIBANA_SECURITY_PASSWORD=your_kibana_password
KIBANA_SECURITY_PORT=5602
PROMETHEUS_SECURITY_PORT=9091
GRAFANA_SECURITY_USER=admin
GRAFANA_SECURITY_PASSWORD=your_grafana_password
GRAFANA_SECURITY_PORT=3002

# Security Scanning Configuration
ZAP_PORT=8090
ZAP_API_KEY=your_zap_api_key_here
TRIVY_PORT=8081
TRIVY_CACHE_DIR=/tmp/trivy-cache
TRIVY_SEVERITY=HIGH,CRITICAL
TRIVITY_SCAN_INTERVAL=24h

# Intrusion Detection System
IDS_ENABLED=true
IDS_INTERFACE=eth0
IDS_RULESET_PATH=/etc/suricata/rules
IDS_LOG_LEVEL=info
IDS_ALERT_THRESHOLD=5

# Secret Management (Vault)
VAULT_PORT=8201
VAULT_ROOT_TOKEN=your_vault_root_token_here
VAULT_UNSEAL_KEY_1=your_unseal_key_1_here
VAULT_UNSEAL_KEY_2=your_unseal_key_2_here
VAULT_UNSEAL_KEY_3=your_unseal_key_3_here
VAULT_TRANSIT_KEY_NAME=ecommerce-transit

# Certificate Management
DOMAIN_NAME=your-domain.com
CERTBOT_EMAIL=admin@your-domain.com
CERTBOT_RENEWAL_SCHEDULE=0 3 * * *
CERTBOT_STAGING=false

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_S3_BUCKET=your-backup-bucket-name
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=true
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# Security Testing Configuration
TEST_SCHEDULE=0 3 * * *
TARGET_URL=https://api.your-domain.com
TEST_TIMEOUT=300
TEST_RETRY_COUNT=3

# GDPR & Compliance Configuration
GDPR_ENABLED=true
GDPR_DPO_EMAIL=dpo@your-domain.com
GDPR_RETENTION_DAYS=2555
GDPR_ANONYMIZATION_ENABLED=true
GDPR_CONSENT_EXPIRY_DAYS=365
GDPR_DATA_EXPORT_FORMAT=json
GDPR_DELETION_VERIFICATION=true

# PCI-DSS Configuration
PCI_DSS_ENABLED=true
PCI_DSS_TOKENIZATION_PROVIDER=stripe
PCI_DSS_3DS_ENABLED=true
PCI_DSS_FRAUD_DETECTION=true
PCI_DSS_AVS_CHECK=true
PCI_DSS_CVV_CHECK=true
PCI_DSS_CARD_DATA_RETENTION_DAYS=90

# Data Breach Configuration
BREACH_NOTIFICATION_ENABLED=true
BREACH_NOTIFICATION_EMAIL=security@your-domain.com
BREACH_NOTIFICATION_THRESHOLD=100
BREACH_AUTO_CONTAINMENT=true
BREACH_INVESTIGATION_TIMEOUT=3600

# Security Policy Configuration
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true
PASSWORD_HISTORY_COUNT=5
PASSWORD_MAX_AGE_DAYS=90
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION=900
SESSION_TIMEOUT_MINUTES=30
MFA_REQUIRED_FOR_ADMIN=true
MFA_REQUIRED_FOR_SENSITIVE=true

# API Security Configuration
API_KEY_LENGTH=32
API_KEY_EXPIRY_DAYS=365
API_VERSION=v1
API_RATE_LIMIT_PER_MINUTE=60
API_REQUEST_TIMEOUT=30000
API_MAX_PAYLOAD_SIZE=10485760

# Database Security Configuration
DB_CONNECTION_POOL_MIN=2
DB_CONNECTION_POOL_MAX=10
DB_CONNECTION_TIMEOUT=30000
DB_QUERY_TIMEOUT=30000
DB_IDLE_TIMEOUT=300000
DB_SSL_VERIFY=true
DB_ROW_LEVEL_SECURITY=true
DB_AUDIT_ENABLED=true

# Email Security Configuration
SMTP_HOST=smtp.your-domain.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=noreply@your-domain.com
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=Security Team <security@your-domain.com>
EMAIL_ENCRYPTION=tls

# SMS Security Configuration
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your_twilio_account_sid
SMS_AUTH_TOKEN=your_twilio_auth_token
SMS_FROM_NUMBER=+1234567890
SMS_RATE_LIMIT_PER_MINUTE=10

# File Upload Security
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf
UPLOAD_SCAN_VIRUSES=true
UPLOAD_QUARANTINE_PATH=/app/quarantine
UPLOAD_RETENTION_DAYS=30

# Development/Testing Security (DISABLE IN PRODUCTION)
DEV_SECURITY_BYPASS=false
DEV_MOCK_AUTH=false
DEV_LOG_REQUESTS=false
DEV_DISABLE_RATE_LIMIT=false
DEV_DISABLE_WAF=false
DEV_DISABLE_ENCRYPTION=false

# Feature Flags
FEATURE_MFA_ENABLED=true
FEATURE_BIOMETRIC_AUTH=false
FEATURE_DEVICE_FINGERPRINTING=true
FEATURE_BEHAVIORAL_ANALYTICS=true
FEATURE_ANOMALY_DETECTION=true
FEATURE_THREAT_INTELLIGENCE=true
FEATURE_ZERO_TRUST=true
FEATURE_MICROSEGMENTATION=true

# Compliance Frameworks
COMPLIANCE_FRAMEWORKS=GDPR,PCI-DSS,ISO27001,SOC2
COMPLIANCE_AUDIT_ENABLED=true
COMPLIANCE_REPORTING_ENABLED=true
COMPLIANCE_AUTOMATION_ENABLED=true
COMPLIANCE_TRAINING_REQUIRED=true

# Incident Response
INCIDENT_RESPONSE_ENABLED=true
INCIDENT_RESPONSE_EMAIL=incident@your-domain.com
INCIDENT_RESPONSE_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
INCIDENT_RESPONSE_PAGERDUTY_KEY=your_pagerduty_key
INCIDENT_RESPONSE_ESCALATION_TIMEOUT=1800

# Third-Party Security Services
SHIELD_ENABLED=false
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
S3_BUCKET_ENCRYPTION=AES256
S3_BUCKET_VERSIONING=true
S3_BUCKET_ACCESS_LOGGING=true

# Performance & Security Balance
SECURITY_CACHE_TTL=300
SECURITY_RATE_LIMIT_CACHE_TTL=60
SECURITY_SESSION_CACHE_TTL=900
SECURITY_TOKEN_CACHE_TTL=300

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_DEPS=database,redis,external-api

# Debug Configuration (DISABLE IN PRODUCTION)
DEBUG_SECURITY=false
DEBUG_REQUESTS=false
DEBUG_RESPONSES=false
DEBUG_ERRORS=false
DEBUG_PERFORMANCE=false

# Monitoring & Alerting
METRICS_ENABLED=true
METRICS_PORT=9464
METRICS_PATH=/metrics
ALERT_EMAIL_ENABLED=true
ALERT_SLACK_ENABLED=true
ALERT_PAGERDUTY_ENABLED=false
ALERT_THRESHOLD_CPU=80
ALERT_THRESHOLD_MEMORY=85
ALERT_THRESHOLD_DISK=90

# Legal & Regulatory
LEGAL_TERMS_VERSION=1.0
LEGAL_PRIVACY_VERSION=1.0
LEGAL_COOKIE_VERSION=1.0
LEGAL_COMPLIANCE_VERSION=1.0
LEGAL_JURISDICTION=US,EU,CA

# Backup & Disaster Recovery
DR_ENABLED=true
DR_RTO_MINUTES=60
DR_RPO_MINUTES=15
DR_BACKUP_FREQUENCY=hourly
DR_TEST_FREQUENCY=monthly
DR_DOCUMENTATION_URL=https://docs.your-domain.com/dr

# End of Security Configuration
