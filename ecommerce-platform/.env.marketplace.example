# Database Configuration
DB_NAME=marketplace
DB_USER=postgres
DB_PASSWORD=your-secure-password
DATABASE_URL=postgresql://postgres:your-secure-password@localhost:5432/marketplace

# Redis Configuration
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@localhost:6379

# Search Engine Configuration
ELASTICSEARCH_URL=http://localhost:9200

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
NEXTAUTH_SECRET=your-nextauth-secret-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Email Configuration (SendGrid)
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Multi-Vendor Marketplace Settings
DEFAULT_COMMISSION_RATE=10.0
MIN_PAYOUT_AMOUNT=10.00
PAYOUT_PROCESSING_FEE=0.025

# Service URLs
VENDOR_SERVICE_URL=http://vendor-service:3001
PAYOUT_SERVICE_URL=http://payout-service:3002
SEARCH_SERVICE_URL=http://search-service:3003

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NODE_ENV=development

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
CACHE_TTL=3600
SEARCH_CACHE_TTL=1800

# Monitoring Configuration
GRAFANA_PASSWORD=admin
PROMETHEUS_RETENTION=30d

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
CORS_ORIGIN=http://localhost:3001
SESSION_SECRET=your-session-secret-change-this

# Email Templates
EMAIL_FROM=noreply@marketplace.com
EMAIL_FROM_NAME=Marketplace

# Vendor Settings
VENDOR_APPROVAL_REQUIRED=true
PRODUCT_APPROVAL_REQUIRED=true
AUTO_PAYOUT_ENABLED=false
PAYOUT_SCHEDULE=daily

# Commission Tiers
COMMISSION_TIER_1_RATE=15.0
COMMISSION_TIER_1_MIN_SALES=0
COMMISSION_TIER_2_RATE=12.0
COMMISSION_TIER_2_MIN_SALES=10000
COMMISSION_TIER_3_RATE=10.0
COMMISSION_TIER_3_MIN_SALES=50000
COMMISSION_TIER_4_RATE=8.0
COMMISSION_TIER_4_MIN_SALES=100000

# Search Configuration
SEARCH_INDEX_NAME=marketplace
SEARCH_RESULTS_PER_PAGE=20
SEARCH_FUZZINESS=2

# Notification Settings
VENDOR_NOTIFICATION_ENABLED=true
CUSTOMER_NOTIFICATION_ENABLED=true
ADMIN_NOTIFICATION_ENABLED=true

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# SSL Configuration (for production)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Performance Settings
MAX_CONNECTIONS=100
CONNECTION_TIMEOUT=30000
QUERY_TIMEOUT=10000

# Development Tools (comment out in production)
ENABLE_DEV_TOOLS=true
REDIS_COMMANDER_PORT=8081
ADMINER_PORT=8080
