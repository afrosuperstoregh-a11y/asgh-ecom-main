# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/ecommerce

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_URL=redis://localhost:6379

# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourstore.com
SENDGRID_FROM_NAME=Your Store

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# CMS Integration
CMS_API_URL=https://your-cms.com/api
CMS_API_KEY=your_cms_api_key_here

# Marketing Configuration
MARKETING_WORKER_CONCURRENCY=5
MARKETING_BATCH_SIZE=100
MARKETING_RETRY_ATTEMPTS=3

# Frontend URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Analytics & Tracking
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
FACEBOOK_PIXEL_ID=your_facebook_pixel_id

# Webhook URLs
WEBHOOK_BASE_URL=http://localhost:3001/api/marketing/webhooks

# Security
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# Development
NODE_ENV=development
LOG_LEVEL=debug
