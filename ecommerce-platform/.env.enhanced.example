# =============================================================================
# E-commerce Platform - Enhanced Environment Variables
# =============================================================================

# Application Environment
NODE_ENV=development
PORT=3001

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL
POSTGRES_DB=ecommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/ecommerce

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis for sessions and caching
REDIS_URL=redis://:redis123@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# =============================================================================
# JWT Configuration
# =============================================================================

# Generate strong secrets for production
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# Email Configuration (SendGrid)
# =============================================================================

# SendGrid API Key - Get from https://dashboard.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your-sendgrid-api-key

# Email configuration
FROM_EMAIL=noreply@yourcompany.com
FROM_NAME=Your Company

# Email templates
EMAIL_TEMPLATES_DIR=./templates/email

# =============================================================================
# SMS Configuration (Twilio)
# =============================================================================

# Twilio Account SID - Get from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# Social OAuth Configuration
# =============================================================================

# Google OAuth - Get from https://console.developers.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Facebook OAuth - Get from https://developers.facebook.com
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:3001/api/auth/facebook/callback

# Apple Sign In - Get from https://developer.apple.com/developer-id
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret
APPLE_REDIRECT_URI=http://localhost:3001/api/auth/apple/callback

# Twitter OAuth - Get from https://developer.twitter.com
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_CALLBACK_URL=http://localhost:3001/api/auth/twitter/callback

# =============================================================================
# Security Configuration
# =============================================================================

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Password Security
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# Session Security
SESSION_SECRET=your-session-secret-change-in-production
SESSION_MAX_AGE=86400000  # 24 hours

# =============================================================================
# File Upload Configuration
# =============================================================================

# Upload settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880  # 5MB
ALLOWED_FILE_TYPES=jpg,jpeg,png,webp

# Image processing
IMAGE_QUALITY=80
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log file settings
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# =============================================================================
# Frontend Configuration
# =============================================================================

# Frontend URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public OAuth IDs (safe to expose)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id

# Feature Flags
NEXT_PUBLIC_ENABLE_SOCIAL_LOGIN=true
NEXT_PUBLIC_ENABLE_2FA=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_CHAT_SUPPORT=false

# =============================================================================
# Analytics and Monitoring
# =============================================================================

# Google Analytics
NEXT_PUBLIC_GA_ID=your-google-analytics-id

# Hotjar
NEXT_PUBLIC_HOTJAR_ID=your-hotjar-id

# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# =============================================================================
# Payment Configuration (Stripe)
# =============================================================================

# Stripe API Keys - Get from https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# =============================================================================
# Production Configuration
# =============================================================================

# SSL Configuration (for production)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Domain Configuration
DOMAIN=yourcompany.com
API_DOMAIN=api.yourcompany.com

# =============================================================================
# Development Tools
# =============================================================================

# Enable development tools
ENABLE_ADMINER=true
ENABLE_REDIS_COMMANDER=true
ENABLE_MAILHOG=true

# Debug settings
DEBUG_SQL=false
DEBUG_REDIS=false
DEBUG_EMAIL=false

# =============================================================================
# Testing Configuration
# =============================================================================

# Test database
TEST_DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/ecommerce_test

# Test Redis
TEST_REDIS_URL=redis://:redis123@localhost:6379/1

# =============================================================================
# Backup Configuration
# =============================================================================

# Database backup
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1

# =============================================================================
# CDN Configuration
# =============================================================================

# AWS S3 for file storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# =============================================================================
# External Services
# =============================================================================

# Elasticsearch (for search)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=ecommerce

# Typesense (alternative search)
TYPESENSE_API_KEY=your-typesense-api-key
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http

# =============================================================================
# Monitoring and Alerting
# =============================================================================

# Health check endpoints
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000

# Metrics
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# =============================================================================
# Legal and Compliance
# =============================================================================

# GDPR Compliance
GDPR_COMPLIANCE=true
DATA_RETENTION_DAYS=365
COOKIE_CONSENT_ENABLED=true

# Privacy Policy
PRIVACY_POLICY_URL=https://yourcompany.com/privacy
TERMS_OF_SERVICE_URL=https://yourcompany.com/terms

# =============================================================================
# Performance Optimization
# =============================================================================

# Caching
CACHE_TTL=3600  # 1 hour
CACHE_MAX_SIZE=1000

# Database connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# =============================================================================
# Development Override
# =============================================================================

# Override any of the above settings for local development
# Copy this file to .env and update the values as needed
