    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "axios": "^1.13.2",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-store": "^3.0.1",
    "lucide-react": "^0.292.0",
    "next": "14.0.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stripe": "^14.0.0",
    "tailwindcss": "^3.3.0",
