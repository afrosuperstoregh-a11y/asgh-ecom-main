{
  "name": "asca-ecommerce-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:backend\"",
    "dev:client": "cd client && npm run dev",
    "dev:backend": "cd backend && npm run start:dev",
    "start:dev": "npm run dev",
    "build": "echo \"Please run build commands in the respective service directories\" && exit 1",
    "start": "echo \"Please start services from their respective directories\" && exit 1",
    "lint": "npm run lint --workspaces"
  },
