  "main": "backend/src/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:backend\"",
    "dev:client": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
