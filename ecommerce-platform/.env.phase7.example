# Phase 7: Advanced Commerce Features Environment Configuration
# Copy this file to .env.phase7 and customize for your environment

# ============================================
# SUBSCRIPTION CONFIGURATION
# ============================================

# Subscription Settings
SUBSCRIPTION_TRIAL_DAYS=14
SUBSCRIPTION_DUNNING_RETRIES=3
SUBSCRIPTION_BILLING_GRACE_PERIOD=7
SUBSCRIPTION_MIN_BILLING_AMOUNT=1.00
SUBSCRIPTION_MAX_QUANTITY=10

# Stripe Subscription Configuration
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=whsec_...
SUBSCRIPTION_INVOICE_DAYS_BEFORE_DUE=7
SUBSCRIPTION_AUTO_RENEWAL_ENABLED=true

# ============================================
# LOYALTY PROGRAM CONFIGURATION
# ============================================

# Points System
LOYALTY_POINTS_PER_DOLLAR=1.00
LOYALTY_POINTS_EXPIRATION_DAYS=365
LOYALTY_MIN_PURCHASE_AMOUNT=1.00
LOYALTY_POINTS_ROUNDING=nearest

# Tier Configuration
LOYALTY_TIER_ADVANCEMENT_ENABLED=true
LOYALTY_TIER_DEMOTION_ENABLED=false
LOYALTY_TIER_REVIEW_PERIOD_DAYS=30

# Birthday Rewards
LOYALTY_BIRTHDAY_BONUS_POINTS=100
LOYALTY_BIRTHDAY_REMINDER_DAYS=7
LOYALTY_ANNIVERSARY_BONUS_POINTS=50

# Referral Rewards
LOYALTY_REFERRAL_BONUS_POINTS=200
LOYALTY_REFERRER_BONUS_POINTS=100
LOYALTY_REVIEW_BONUS_POINTS=25

# ============================================
# AFFILIATE PROGRAM CONFIGURATION
# ============================================

# Commission Settings
AFFILIATE_COMMISSION_RATE=10.00
AFFILIATE_RECURRING_COMMISSION_RATE=5.00
AFFILIATE_TIER_BONUS_RATE=2.00
AFFILIATE_COOKIE_DURATION=30
AFFILIATE_CONVERSION_WINDOW=30

# Payout Configuration
AFFILIATE_PAYOUT_THRESHOLD=50.00
AFFILIATE_PAYOUT_FREQUENCY=monthly
AFFILIATE_PAYOUT_DAY_OF_MONTH=1
AFFILIATE_PROCESSING_FEE_PERCENT=2.9
AFFILIATE_PROCESSING_FEE_FIXED=0.30

# Stripe Connect Configuration
STRIPE_CONNECT_CLIENT_ID=ca_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
AFFILIATE_ONBOARDING_ENABLED=true

# Fraud Detection
AFFILIATE_FRAUD_DETECTION_ENABLED=true
AFFILIATE_MAX_DAILY_CLICKS=1000
AFFILIATE_SUSPICIOUS_CONVERSION_RATE=50.0

# ============================================
# NOTIFICATION CONFIGURATION
# ============================================

# Subscription Notifications
SUBSCRIPTION_NOTIFICATIONS_ENABLED=true
SUBSCRIPTION_WELCOME_EMAIL_ENABLED=true
SUBSCRIPTION_BILLING_REMINDER_ENABLED=true
SUBSCRIPTION_PAYMENT_FAILED_ENABLED=true
SUBSCRIPTION_CANCELLED_ENABLED=true

# Loyalty Notifications
LOYALTY_NOTIFICATIONS_ENABLED=true
LOYALTY_POINTS_EARNED_ENABLED=true
LOYALTY_TIER_ADVANCEMENT_ENABLED=true
LOYALTY_POINTS_EXPIRING_ENABLED=true
LOYALTY_BIRTHDAY_REWARD_ENABLED=true

# Affiliate Notifications
AFFILIATE_NOTIFICATIONS_ENABLED=true
AFFILIATE_APPROVAL_NOTIFICATION_ENABLED=true
AFFILIATE_COMMISSION_EARNED_ENABLED=true
AFFILIATE_PAYOUT_PROCESSED_ENABLED=true

# ============================================
# CACHE CONFIGURATION
# ============================================

# Redis Cache TTL (in seconds)
CACHE_SUBSCRIPTION_PLANS_TTL=3600
CACHE_CUSTOMER_SUBSCRIPTIONS_TTL=900
CACHE_LOYALTY_STATUS_TTL=600
CACHE_AFFILIATE_DASHBOARD_TTL=300
CACHE_POINTS_BALANCE_TTL=300
CACHE_COMMISSION_RATES_TTL=1800

# Cache Keys
CACHE_KEY_SUBSCRIPTION_PLANS=subscription:plans
CACHE_KEY_LOYALTY_TIERS=loyalty:tiers
CACHE_KEY_AFFILIATE_TIERS=affiliate:tiers

# ============================================
# RATE LIMITING CONFIGURATION
# ============================================

# Subscription API Rate Limits
RATE_LIMIT_SUBSCRIPTION_API_REQUESTS=100
RATE_LIMIT_SUBSCRIPTION_API_WINDOW=900

# Loyalty API Rate Limits
RATE_LIMIT_LOYALTY_API_REQUESTS=200
RATE_LIMIT_LOYALTY_API_WINDOW=900

# Affiliate API Rate Limits
RATE_LIMIT_AFFILIATE_API_REQUESTS=150
RATE_LIMIT_AFFILIATE_API_WINDOW=900

# ============================================
# BUSINESS RULES CONFIGURATION
# ============================================

# Subscription Business Rules
SUBSCRIPTION_MAX_CONCURRENT_PER_USER=5
SUBSCRIPTION_CHANGE_COOLDOWN_HOURS=24
SUBSCRIPTION_PAUSE_MAX_DAYS=90
SUBSCRIPTION_CANCEL_REFUND_POLICY=pro_rata

# Loyalty Business Rules
LOYALTY_MAX_REDEMPTIONS_PER_DAY=5
LOYALTY_MIN_REDEMPTION_POINTS=100
LOYALTY_POINTS_TRANSFER_ENABLED=false
LOYALTY_GIFTING_ENABLED=false

# Affiliate Business Rules
AFFILIATE_SELF_REFERRAL_ALLOWED=false
AFFILIATE_MULTIPLE_LEVELS_ENABLED=false
AFFILIATE_COUPON_SHARING_ENABLED=true
AFFILIATE_PERFORMANCE_BONUS_ENABLED=true

# ============================================
# ANALYTICS CONFIGURATION
# ============================================

# Analytics Data Retention (days)
ANALYTICS_SUBSCRIPTION_DATA_RETENTION=1095
ANALYTICS_LOYALTY_DATA_RETENTION=1825
ANALYTICS_AFFILIATE_DATA_RETENTION=1825

# Reporting Configuration
REPORTING_DAILY_SUMMARY_ENABLED=true
REPORTING_WEEKLY_DIGEST_ENABLED=true
REPORTING_MONTHLY_ANALYTICS_ENABLED=true

# ============================================
# SECURITY CONFIGURATION
# ============================================

# JWT Configuration for Affiliate Dashboard
AFFILIATE_JWT_SECRET=your_affiliate_jwt_secret_here
AFFILIATE_JWT_EXPIRES_IN=7d

# Webhook Security
WEBHOOK_SIGNATURE_ENABLED=true
WEBHOOK_TIMEOUT_MS=30000
WEBHOOK_RETRY_ATTEMPTS=3

# Data Privacy
DATA_ANONYMIZATION_ENABLED=false
DATA_RETENTION_COMPLIANCE_ENABLED=true
GDPR_COMPLIANCE_ENABLED=true

# ============================================
# INTEGRATION CONFIGURATION
# ============================================

# SendGrid Templates
SENDGRID_TEMPLATE_SUBSCRIPTION_WELCOME=template_subscription_welcome
SENDGRID_TEMPLATE_BILLING_REMINDER=template_billing_reminder
SENDGRID_TEMPLATE_PAYMENT_FAILED=template_payment_failed
SENDGRID_TEMPLATE_LOYALTY_TIER_UPGRADE=template_tier_upgrade
SENDGRID_TEMPLATE_POINTS_EXPIRING=template_points_expiring
SENDGRID_TEMPLATE_AFFILIATE_APPROVAL=template_affiliate_approval

# Twilio Configuration
TWILIO_SUBSCRIPTION_ALERTS_ENABLED=false
TWILIO_LOYALTY_ALERTS_ENABLED=false
TWILIO_AFFILIATE_ALERTS_ENABLED=false

# ============================================
# DEVELOPMENT & DEBUGGING
# ============================================

# Debug Mode
PHASE7_DEBUG_MODE=false
PHASE7_VERBOSE_LOGGING=false
PHASE7_PERFORMANCE_MONITORING=true

# Feature Flags
FEATURE_SUBSCRIPTION_MANAGEMENT=true
FEATURE_LOYALTY_PROGRAM=true
FEATURE_AFFILIATE_PROGRAM=true
FEATURE_ADVANCED_ANALYTICS=true

# Testing Configuration
PHASE7_TEST_MODE=false
PHASE7_STRIPE_TEST_MODE=true
PHASE7_EMAIL_TEST_MODE=false

# ============================================
# MONITORING & ALERTING
# ============================================

# Health Checks
HEALTH_CHECK_SUBSCRIPTION_SERVICE=true
HEALTH_CHECK_LOYALTY_SERVICE=true
HEALTH_CHECK_AFFILIATE_SERVICE=true

# Alerting Thresholds
ALERT_SUBSCRIPTION_CHURN_RATE_THRESHOLD=10.0
ALERT_LOYALTY_ENGAGEMENT_RATE_THRESHOLD=50.0
ALERT_AFFILIATE_CONVERSION_RATE_THRESHOLD=2.0

# Performance Monitoring
PERFORMANCE_SLOW_QUERY_THRESHOLD_MS=1000
PERFORMANCE_MEMORY_USAGE_THRESHOLD_MB=512
PERFORMANCE_CPU_USAGE_THRESHOLD_PERCENT=80
