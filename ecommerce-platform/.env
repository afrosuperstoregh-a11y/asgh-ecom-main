# Application
NODE_ENV=development
PORT=3001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/ecommerce?schema=public

# Redis
REDIS_URL=redis://:your_redis_password@redis:6379

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=30d

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Typesense
TYPESENSE_API_KEY=your_typesense_api_key
TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=no-reply@yourapp.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Next.js Public Variables
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Canada Post
CANADA_POST_ENV=development
# Development Credentials
CANADA_POST_DEV_BASE_URL=https://ct.soa-gw.canadapost.ca
CANADA_POST_DEV_KEY=your_dev_canadapost_key
CANADA_POST_DEV_SECRET=your_dev_canadapost_secret
CANADA_POST_DEV_CUSTOMER_NUMBER=your_dev_customer_number
CANADA_POST_DEV_CONTRACT_ID=your_dev_contract_id
# Production Credentials
CANADA_POST_PROD_BASE_URL=https://soa-gw.canadapost.ca
CANADA_POST_PROD_KEY=your_prod_canadapost_key
CANADA_POST_PROD_SECRET=your_prod_canadapost_secret
CANADA_POST_PROD_CUSTOMER_NUMBER=your_prod_customer_number
CANADA_POST_PROD_CONTRACT_ID=your_prod_contract_id
# Shipping Defaults
CANADA_POST_DEFAULT_SHIP_FROM_POSTAL_CODE=H3B2Y5
CANADA_POST_DEFAULT_SHIP_FROM_CITY=Montreal
CANADA_POST_DEFAULT_SHIP_FROM_PROVINCE=QC
CANADA_POST_DEFAULT_SHIP_FROM_COUNTRY=CA
