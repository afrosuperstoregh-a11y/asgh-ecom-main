# Docker ignore file for production builds
# Excludes unnecessary files from Docker context

# Node modules (installed in container)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs (recreated in container)
.next/
out/
dist/
build/

# Environment files (use mounted secrets)
.env.local
.env.development.local
.env.test.local
.env.production.local

# Development files
.git/
.gitignore
README.md
Dockerfile*
docker-compose*
.dockerignore

# Testing and coverage
coverage/
.nyc_output/
__tests__/
*.test.js
*.test.ts
*.spec.js
*.spec.ts

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
.tmp/

# Documentation
docs/
*.md
!README.md

# CI/CD files
.github/
.gitlab-ci.yml
.travis.yml

# Local development
.local/
.cache/

# Database files
*.sqlite
*.sqlite3
*.db

# Upload directories
uploads/
public/uploads/

# Cache directories
.cache/
.parcel-cache/

# Package manager lock files (keep package-lock.json)
yarn.lock
pnpm-lock.yaml
