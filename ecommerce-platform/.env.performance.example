# Performance & Scalability Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Primary Database
POSTGRES_DB=ecommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password-change-in-production

# Database Replication
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=your-secure-replication-password-change-in-production

# Connection Pooling (PgBouncer)
PGBOouncer_POOL_MODE=transaction
PGBOouncer_MAX_CLIENT_CONN=1000
PGBOouncer_DEFAULT_POOL_SIZE=20
PGBOouncer_MIN_POOL_SIZE=5
PGBOouncer_RESERVE_POOL_SIZE=5
PGBOouncer_RESERVE_POOL_TIMEOUT=5

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis Cluster
REDIS_PASSWORD=your-secure-redis-password-change-in-production
REDIS_CLUSTER_NODES=redis-master:6379,redis-slave-1:6379,redis-slave-2:6379

# Redis Queue
REDIS_QUEUE_DB=1
REDIS_QUEUE_CONCURRENCY=10

# Cache TTL Settings
CACHE_TTL_DEFAULT=3600
CACHE_TTL_SHORT=300
CACHE_TTL_LONG=86400
CACHE_TTL_USER_SESSION=1800
CACHE_TTL_API_RESPONSE=600

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Application Performance
NODE_ENV=production
ENABLE_COMPRESSION=true
ENABLE_HTTP2=true
ENABLE_CACHING=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_UPLOAD_MAX=10

# API Performance
API_TIMEOUT=30000
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY=1000

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Application Performance Monitoring
NEW_RELIC_LICENSE_KEY=your-newrelic-license-key
NEW_RELIC_APP_NAME=ecommerce-platform
NEW_RELIC_LOG_LEVEL=info

# DataDog Monitoring
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key
DATADOG_SITE=datadoghq.com

# Grafana Configuration
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-secure-grafana-password-change-in-production

# Prometheus Configuration
PROMETHEUS_RETENTION=200h
PROMETHEUS_SCRAPE_INTERVAL=15s

# =============================================================================
# CDN & STATIC ASSETS
# =============================================================================

# CloudFlare CDN
CDN_URL=https://cdn.yourdomain.com
CDN_API_KEY=your-cloudflare-api-key
CDN_ZONE_ID=your-cloudflare-zone-id
CDN_EMAIL=your-cloudflare-email

# Image Optimization
IMAGE_CDN_URL=https://images.yourdomain.com
IMAGE_QUALITY=80
IMAGE_FORMAT_WEBP=true
IMAGE_FORMAT_AVIF=true

# =============================================================================
# LOAD BALANCING & SCALING
# =============================================================================

# Load Balancer Configuration
LOAD_BALANCER_ALGORITHM=round_robin
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_PATH=/health

# Auto-scaling Configuration
AUTOSCALING_MIN_REPLICAS=2
AUTOSCALING_MAX_REPLICAS=10
AUTOSCALING_CPU_THRESHOLD=70
AUTOSCALING_MEMORY_THRESHOLD=80
AUTOSCALING_RESPONSE_TIME_THRESHOLD=500

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# Security Headers
HELMET_ENABLED=true
HELMET_CSP_DIRECTIVE=default-src 'self'
HELMET_HSTS_MAX_AGE=31536000

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# SendGrid Email Service
SENDGRID_API_KEY=SG.your-sendgrid-api-key
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Your Company Name

# Twilio SMS Service
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Social OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# =============================================================================
# FILE UPLOAD & STORAGE
# =============================================================================

# File Upload Configuration
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx
IMAGE_MAX_WIDTH=2048
IMAGE_MAX_HEIGHT=2048

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Application Logging
LOG_LEVEL=info
LOG_FILE=/app/logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
LOG_DATE_FORMAT=YYYY-MM-DD HH:mm:ss

# Error Tracking
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# FRONTEND PERFORMANCE
# =============================================================================

# Next.js Configuration
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_CDN_URL=https://cdn.yourdomain.com

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_HOTJAR_ID=123456
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Feature Flags
NEXT_PUBLIC_ENABLE_SOCIAL_LOGIN=true
NEXT_PUBLIC_ENABLE_2FA=false
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_OFFLINE=true

# Performance Budgets
NEXT_PUBLIC_BUNDLE_SIZE_LIMIT=244000
NEXT_PUBLIC_CHUNK_SIZE_LIMIT=24400
NEXT_PUBLIC_IMAGE_SIZE_LIMIT=100000

# =============================================================================
# BACKGROUND JOBS
# =============================================================================

# Job Queue Configuration
JOB_CONCURRENCY=10
JOB_MAX_ATTEMPTS=3
JOB_BACKOFF_TYPE=exponential
JOB_BACKOFF_DELAY=2000
JOB_REMOVE_ON_COMPLETE=100
JOB_REMOVE_ON_FAIL=50

# Scheduled Jobs
CRON_EMAIL_DIGEST=0 8 * * *
CRON_CLEANUP_SESSIONS=0 2 * * *
CRON_GENERATE_REPORTS=0 6 * * 1
CRON_CACHE_WARMING=0 */4 * * *

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================

# Development Tools
ENABLE_DEBUG=false
ENABLE_PROFILING=false
ENABLE_SWAGGER=true
ENABLE_GRAPHQL_PLAYGROUND=true

# Testing Configuration
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ecommerce_test
TEST_REDIS_URL=redis://localhost:6380/1

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================

# Database Backup
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key

# Disaster Recovery
RTO_TARGET=300
RPO_TARGET=60
FAILOVER_ENABLED=true
FAILOVER_TIMEOUT=30

# =============================================================================
# COMPLIANCE & GOVERNANCE
# =============================================================================

# GDPR Compliance
GDPR_ENABLED=true
GDPR_RETENTION_DAYS=365
GDPR_ANONYMIZATION_ENABLED=true

# Security Compliance
SECURITY_SCAN_ENABLED=true
VULNERABILITY_SCAN_ENABLED=true
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555

# =============================================================================
# MISC CONFIGURATION
# =============================================================================

# Application Settings
APP_NAME=E-Commerce Platform
APP_VERSION=4.0.0
APP_DESCRIPTION=High-performance e-commerce platform
APP_SUPPORT_EMAIL=support@yourdomain.com

# Timezone & Locale
TZ=UTC
DEFAULT_LOCALE=en-US
SUPPORTED_LOCALES=en-US,es-ES,fr-FR,de-DE,it-IT

# Currency & Pricing
DEFAULT_CURRENCY=USD
SUPPORTED_CURRENCIES=USD,EUR,GBP,CAD,AUD,JPY
TAX_CALCULATION_ENABLED=true
SHIPPING_CALCULATION_ENABLED=true
