# Afro Superstore Backend Environment Configuration
# Production-ready environment variables template

# Server Configuration
NODE_ENV=production
PORT=3001
HOSTNAME=0.0.0.0

# Supabase Configuration (REQUIRED - Primary Database & Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Redis Configuration (Optional - for caching and sessions)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=asca_ecom:

# Cache Configuration
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300
CACHE_PRODUCT_LIST_TTL=300
CACHE_PRODUCT_DETAILS_TTL=600
CACHE_CATEGORIES_TTL=1800

# CORS Configuration
CORS_ORIGINS=https://www.afrosuperstore.ca,https://afrosuperstore.ca,http://localhost:3000

# Frontend URLs
FRONTEND_URL=https://www.afrosuperstore.ca
SITE_URL=https://www.afrosuperstore.ca

# Payment Configuration
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Paystack Configuration (Ghana Payments)
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key_here
PAYSTACK_BASE_URL=https://api.paystack.co

# Email Configuration
SENDGRID_API_KEY=SG.your_sendgrid_api_key
FROM_EMAIL=noreply@afrosuperstore.ca
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key

# Admin Account Setup (for initial admin creation)
ADMIN_EMAIL=admin@afrosuperstore.ca
ADMIN_PASSWORD=your_secure_admin_password

# Security Configuration
SESSION_SECRET=your_strong_session_secret_minimum_32_characters
ENCRYPTION_KEY=your_encryption_key_here
ALLOWED_EXTENSION_IDS=extension_id_1,extension_id_2

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE_ENABLED=true

# Monitoring & Analytics
VERCEL_ANALYTICS_ID=your_vercel_analytics_id
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# File Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Development Overrides (set to false in production)
DEV_MODE=false
DEBUG_SQL=false
DEBUG_AUTH=false
