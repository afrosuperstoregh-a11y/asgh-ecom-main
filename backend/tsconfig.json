{
  "compilerOptions": {
        "target": "ES5",
    "module": "commonjs",
                "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
        "types": ["node"],
    "declaration": true,
    "emitDeclarationOnly": false
  },
  "include": [
    "**/*.ts",
    "types/**/*.d.ts",
    "services/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src"
  ]
}
